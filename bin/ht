#!/usr/bin/env bun
/**
 * ht — HyperTerm Canvas CLI
 * Controls HyperTerm Canvas via Unix socket (JSON-RPC).
 */

import { connect } from "net";
import { readFileSync } from "node:fs";

const SOCKET_PATH = process.env["HT_SOCKET_PATH"] || "/tmp/hyperterm.sock";

/** Shared browser-help block. Used by the global `ht --help` banner
 *  (interpolated into `printHelp`), by `ht browser help`, and by the
 *  `--help` / `-h` short-circuit inside `mapBrowserSubcommand`. Hoisted
 *  to the top of the file because all three call sites can fire before
 *  any later top-level statement runs (TDZ). */
const BROWSER_HELP = `Browser (use: ht browser [surface] <subcommand> [args...]):
  ht browser open [url]                     Open browser split (or navigate if surface given)
  ht browser open-split [url]               Split browser alongside current pane
  ht browser [S] navigate <url>             Navigate to URL
  ht browser [S] back|forward|reload        Navigation
  ht browser [S] url                        Print current URL
  ht browser [S] identify                   Show browser surface metadata

  ht browser [S] wait --selector|--text|--url-contains|--load-state|--function [--timeout-ms N]

  ht browser [S] click <sel>                Click element
  ht browser [S] dblclick|hover|focus <sel> Mouse actions
  ht browser [S] check|uncheck <sel>        Checkbox toggle
  ht browser [S] scroll-into-view <sel>     Scroll element into view
  ht browser [S] type <sel> <text>          Type text into element
  ht browser [S] fill <sel> [text]          Fill input (empty = clear)
  ht browser [S] press|keydown|keyup <key>  Keyboard events
  ht browser [S] select <sel> <value>       Select dropdown option
  ht browser [S] scroll [--dx N] [--dy N]   Scroll page or element
  ht browser [S] highlight <sel>            Highlight element (3s)

  ht browser [S] snapshot [--selector sel] [--max-depth N]
  ht browser [S] get <title|url|text|html|value|attr|count|box|styles> [sel]
  ht browser [S] is <visible|enabled|checked> <sel>

  ht browser [S] eval <script>              Execute JavaScript
  ht browser [S] addscript <script>         Inject JavaScript
  ht browser [S] addstyle <css>             Inject CSS

  ht browser [S] console [list|clear]       Page console messages
  ht browser [S] errors [list|clear]        Page errors

  ht browser [S] devtools                   Toggle developer tools
  ht browser [S] find-in-page <query>       Find text in page
  ht browser history [clear]                Browser history
  ht browser list                           List all browser surfaces
  ht browser [S] close                      Close browser surface

  Cookie Management (use: ht browser-cookie-<cmd>):
  browser-cookie-list [domain]              List stored cookies
  browser-cookie-get <url>                  Get cookies matching a URL
  browser-cookie-set <name> <value> --domain <d> [--path /] [--secure true]
  browser-cookie-delete <domain> <name>     Delete a specific cookie
  browser-cookie-clear [domain]             Clear cookies (all or per-domain)
  browser-cookie-import <file> [--format json|netscape]  Import cookie file
  browser-cookie-export [--format json|netscape]         Export all cookies
  browser-cookie-capture [--surface S]      Capture cookies from current page

  [S] = optional --surface browser:N or positional browser:N

  Legacy aliases: browser-open, browser-split, browser-navigate, etc.`;

const args = process.argv.slice(2);
const command = args[0];

if (!command || command === "--help" || command === "-h") {
  printHelp();
  process.exit(0);
}

// Parse flags from remaining args
function parseFlags(
  a: string[],
): { positional: string[]; flags: Record<string, string> } {
  const positional: string[] = [];
  const flags: Record<string, string> = {};
  let i = 0;
  while (i < a.length) {
    if (a[i].startsWith("--")) {
      const key = a[i].slice(2);
      const val = a[i + 1] && !a[i + 1].startsWith("--") ? a[i + 1] : "true";
      flags[key] = val;
      i += val === "true" ? 1 : 2;
    } else if (a[i].startsWith("-") && a[i].length === 2) {
      const key = a[i].slice(1);
      const val = a[i + 1] && !a[i + 1].startsWith("-") ? a[i + 1] : "true";
      flags[key] = val;
      i += val === "true" ? 1 : 2;
    } else {
      positional.push(a[i]);
      i++;
    }
  }
  return { positional, flags };
}

const { positional, flags } = parseFlags(args.slice(1));

function unescapeText(s: string): string {
  return s
    .replace(/\\n/g, "\r")
    .replace(/\\r/g, "\r")
    .replace(/\\t/g, "\t")
    .replace(/\\x1b/g, "\x1b")
    .replace(/\\\\/g, "\\");
}

// Map CLI command → JSON-RPC method + params
interface RpcCall {
  method: string;
  params: Record<string, unknown>;
}

/**
 * Map `ht browser [surface] <subcommand> [args...]` to RPC calls.
 * Supports cmux-style positional surface targeting:
 *   ht browser browser:2 click "#btn"
 *   ht browser --surface browser:2 click "#btn"
 */
function mapBrowserSubcommand(): RpcCall {
  // `--help` / `-h` get consumed by parseFlags as flags, so they never
  // appear as a positional subcommand. Catch them up-front before the
  // identify-fallback branch turns "no subcommand" into an RPC call.
  if (flags["help"] === "true" || flags["h"] === "true") {
    console.log(BROWSER_HELP);
    process.exit(0);
  }

  // Parse: positional[0] might be a surface ref or a subcommand
  let surfaceId: string | undefined = flags["surface"];
  let sub: string;
  let subArgs: string[];

  if (positional[0]?.startsWith("browser:") || positional[0]?.startsWith("surface:")) {
    surfaceId = positional[0];
    sub = positional[1] || "identify";
    subArgs = positional.slice(2);
  } else {
    sub = positional[0] || "identify";
    subArgs = positional.slice(1);
  }

  const sid = surfaceId;
  const snapshotAfter = flags["snapshot-after"] === "true" || flags["snapshot_after"] === "true";

  switch (sub) {
    // Navigation
    case "open":
      return { method: sid ? "browser.navigate" : "browser.open", params: { surface_id: sid, url: subArgs[0] } };
    case "open-split":
      return { method: "browser.open_split", params: { url: subArgs[0], direction: flags["direction"] || "right" } };
    case "goto":
    case "navigate":
      return { method: "browser.navigate", params: { surface_id: sid, url: subArgs[0] } };
    case "back":
      return { method: "browser.back", params: { surface_id: sid } };
    case "forward":
      return { method: "browser.forward", params: { surface_id: sid } };
    case "reload":
      return { method: "browser.reload", params: { surface_id: sid } };
    case "url":
    case "get-url":
      return { method: "browser.url", params: { surface_id: sid } };
    case "identify":
      return { method: "browser.identify", params: { surface_id: sid } };

    // Wait
    case "wait":
      return {
        method: "browser.wait",
        params: {
          surface_id: sid,
          selector: flags["selector"],
          text: flags["text"],
          url_contains: flags["url-contains"] || flags["url_contains"],
          load_state: flags["load-state"] || flags["load_state"],
          function: flags["function"],
          timeout_ms: flags["timeout-ms"] || flags["timeout_ms"],
        },
      };

    // DOM Interaction
    case "click":
      return { method: "browser.click", params: { surface_id: sid, selector: subArgs[0], snapshot_after: snapshotAfter } };
    case "dblclick":
      return { method: "browser.dblclick", params: { surface_id: sid, selector: subArgs[0] } };
    case "hover":
      return { method: "browser.hover", params: { surface_id: sid, selector: subArgs[0] } };
    case "focus":
      return { method: "browser.focus", params: { surface_id: sid, selector: subArgs[0] } };
    case "check":
      return { method: "browser.check", params: { surface_id: sid, selector: subArgs[0] } };
    case "uncheck":
      return { method: "browser.uncheck", params: { surface_id: sid, selector: subArgs[0] } };
    case "scroll-into-view":
      return { method: "browser.scroll_into_view", params: { surface_id: sid, selector: subArgs[0] } };
    case "type":
      return { method: "browser.type", params: { surface_id: sid, selector: subArgs[0], text: subArgs[1] || flags["text"] } };
    case "fill":
      return { method: "browser.fill", params: { surface_id: sid, selector: subArgs[0], text: subArgs[1] ?? flags["text"] ?? "" } };
    case "press":
      return { method: "browser.press", params: { surface_id: sid, key: subArgs[0] } };
    case "keydown":
      return { method: "browser.press", params: { surface_id: sid, key: subArgs[0] } };
    case "keyup":
      return { method: "browser.press", params: { surface_id: sid, key: subArgs[0] } };
    case "select":
      return { method: "browser.select", params: { surface_id: sid, selector: subArgs[0], value: subArgs[1] } };
    case "scroll":
      return { method: "browser.scroll", params: { surface_id: sid, selector: flags["selector"], dx: flags["dx"], dy: flags["dy"] } };
    case "highlight":
      return { method: "browser.highlight", params: { surface_id: sid, selector: subArgs[0] } };

    // Inspection
    case "snapshot":
      return {
        method: "browser.snapshot",
        params: {
          surface_id: sid,
          selector: flags["selector"],
          max_depth: flags["max-depth"] || flags["max_depth"],
          interactive: flags["interactive"] === "true" || flags["i"] === "true",
          compact: flags["compact"] === "true",
        },
      };
    case "get":
      return {
        method: "browser.get",
        params: {
          surface_id: sid,
          what: subArgs[0],
          selector: subArgs[1] || flags["selector"],
          attr: flags["attr"],
          property: flags["property"],
        },
      };
    case "is":
      return {
        method: "browser.is",
        params: {
          surface_id: sid,
          check: subArgs[0],
          selector: subArgs[1] || flags["selector"],
        },
      };

    // Eval / injection
    case "eval":
      return { method: "browser.eval", params: { surface_id: sid, script: subArgs[0] || flags["script"] } };
    case "addscript":
      return { method: "browser.addscript", params: { surface_id: sid, script: subArgs[0] } };
    case "addstyle":
      return { method: "browser.addstyle", params: { surface_id: sid, css: subArgs[0] } };

    // Console & errors
    case "console":
      if (subArgs[0] === "clear") return { method: "browser.console_clear", params: { surface_id: sid } };
      return { method: "browser.console_list", params: { surface_id: sid } };
    case "errors":
      if (subArgs[0] === "clear") return { method: "browser.errors_clear", params: { surface_id: sid } };
      return { method: "browser.errors_list", params: { surface_id: sid } };

    // Find in page
    case "find-in-page":
      return { method: "browser.find", params: { surface_id: sid, query: subArgs[0] } };

    // DevTools
    case "devtools":
      return { method: "browser.devtools", params: { surface_id: sid } };

    // History
    case "history":
      if (subArgs[0] === "clear") return { method: "browser.clear_history", params: {} };
      return { method: "browser.history", params: {} };

    // Close
    case "close":
      return { method: "browser.close", params: { surface_id: sid } };

    // List
    case "list":
      return { method: "browser.list", params: {} };

    case "help":
      // The `default` branch tells users to run `ht browser help`, so
      // that command must actually work. Print the same browser section
      // surfaced by `ht --help`, then exit cleanly without making an RPC.
      console.log(BROWSER_HELP);
      process.exit(0);

    default:
      console.error(`Unknown browser subcommand: ${sub}`);
      console.error('Run "ht browser help" for usage.');
      process.exit(1);
  }
}

function mapCommand(): RpcCall {
  switch (command) {
    case "ping":
      return { method: "system.ping", params: {} };
    case "version":
      return { method: "system.version", params: {} };
    case "identify":
      return { method: "system.identify", params: {} };
    case "capabilities":
      return { method: "system.capabilities", params: {} };
    case "tree":
      return { method: "system.tree", params: {} };

    case "list-workspaces":
      return { method: "workspace.list", params: {} };
    case "current-workspace":
      return { method: "workspace.current", params: {} };
    case "new-workspace":
      return {
        method: "workspace.create",
        params: { name: flags["name"], cwd: flags["cwd"] },
      };
    case "select-workspace":
      return {
        method: "workspace.select",
        params: { workspace_id: flags["workspace"] },
      };
    case "close-workspace":
      return {
        method: "workspace.close",
        params: { workspace_id: flags["workspace"] },
      };
    case "rename-workspace":
      return {
        method: "workspace.rename",
        params: {
          workspace_id: flags["workspace"],
          name: positional[0],
        },
      };
    case "next-workspace":
      return { method: "workspace.next", params: {} };
    case "previous-workspace":
      return { method: "workspace.previous", params: {} };

    case "list-surfaces":
      return { method: "surface.list", params: {} };
    case "new-split":
      return {
        method: "surface.split",
        params: { direction: positional[0] || "right" },
      };
    case "close-surface":
      return {
        method: "surface.close",
        params: { surface_id: flags["surface"] },
      };
    case "focus-surface":
      return {
        method: "surface.focus",
        params: { surface_id: flags["surface"] },
      };

    case "send":
      return {
        method: "surface.send_text",
        params: {
          surface_id: flags["surface"],
          text: unescapeText(positional[0] || ""),
        },
      };
    case "send-key":
      return {
        method: "surface.send_key",
        params: {
          surface_id: flags["surface"],
          key: positional[0],
        },
      };
    case "read-screen":
      return {
        method: "surface.read_text",
        params: {
          surface_id: flags["surface"],
          lines: flags["lines"] ? parseInt(flags["lines"]) : undefined,
          scrollback: flags["scrollback"] === "true",
        },
      };

    case "screenshot": {
      // `ht screenshot` captures the app window via macOS
      // `screencapture -l <windowId>`. Without --full-window, the
      // result is cropped to the target surface (focused by default,
      // or --surface / HT_SURFACE). Output path is optional — when
      // omitted, a timestamped PNG lands in the system tmpdir.
      //
      // `ht screenshot surface` is a long-form alias kept so the help
      // text and the `ht screenshot <target>` form both parse: the
      // token is consumed as a positional but has no effect beyond the
      // command routing.
      const target = positional[0];
      const fullWindow =
        flags["full-window"] === "true" || target === "window";
      return {
        method: "surface.screenshot",
        params: {
          surface_id: fullWindow
            ? undefined
            : flags["surface"] || process.env["HT_SURFACE"] || undefined,
          output: flags["output"] || flags["o"],
          full_window: fullWindow,
        },
      };
    }

    case "list-panes":
      return { method: "pane.list", params: {} };

    case "metadata":
    case "cwd":
    case "ps":
    case "ports":
    case "git":
      return {
        method: "surface.metadata",
        params: {
          surface_id: flags["surface"] || process.env["HT_SURFACE"] || undefined,
        },
      };

    case "wait-ready":
    case "wait_ready":
      return {
        method: "surface.wait_ready",
        params: {
          surface_id: flags["surface"] || process.env["HT_SURFACE"] || undefined,
          timeout_ms: flags["timeout-ms"] || flags["timeout_ms"]
            ? Number(flags["timeout-ms"] || flags["timeout_ms"])
            : undefined,
        },
      };

    case "open":
      return {
        method: "surface.open_port",
        params: {
          surface_id: flags["surface"] || process.env["HT_SURFACE"] || undefined,
          port: positional[0] ? parseInt(positional[0], 10) : undefined,
        },
      };

    case "kill":
      return {
        method: "surface.kill_port",
        params: {
          surface_id: flags["surface"] || process.env["HT_SURFACE"] || undefined,
          port: positional[0] ? parseInt(positional[0], 10) : undefined,
          signal: flags["signal"],
        },
      };

    case "set-status":
      return {
        method: "sidebar.set_status",
        params: {
          workspace_id: flags["workspace"],
          surface_id:
            flags["surface"] || process.env["HT_SURFACE"] || undefined,
          key: positional[0],
          value: positional[1],
          icon: flags["icon"],
          color: flags["color"],
        },
      };
    case "clear-status":
      return {
        method: "sidebar.clear_status",
        params: {
          workspace_id: flags["workspace"],
          surface_id:
            flags["surface"] || process.env["HT_SURFACE"] || undefined,
          key: positional[0],
        },
      };
    case "set-progress":
      return {
        method: "sidebar.set_progress",
        params: {
          workspace_id: flags["workspace"],
          surface_id:
            flags["surface"] || process.env["HT_SURFACE"] || undefined,
          value: parseFloat(positional[0] || "0"),
          label: flags["label"],
        },
      };
    case "clear-progress":
      return {
        method: "sidebar.clear_progress",
        params: {
          workspace_id: flags["workspace"],
          surface_id:
            flags["surface"] || process.env["HT_SURFACE"] || undefined,
        },
      };
    case "log":
      return {
        method: "sidebar.log",
        params: {
          workspace_id: flags["workspace"],
          surface_id:
            flags["surface"] || process.env["HT_SURFACE"] || undefined,
          level: flags["level"] || "info",
          message: positional[0],
          source: flags["source"],
        },
      };

    case "notify":
      return {
        method: "notification.create",
        params: {
          title: flags["title"] || positional[0] || "",
          subtitle: flags["subtitle"],
          body: flags["body"] || positional[1] || "",
          surface_id:
            flags["surface"] || process.env["HT_SURFACE"] || undefined,
        },
      };
    case "list-notifications":
      return { method: "notification.list", params: {} };
    case "clear-notifications":
      return { method: "notification.clear", params: {} };

    // ── Browser (unified `ht browser <sub>` command, cmux-compatible) ──

    case "browser":
      return mapBrowserSubcommand();

    // Legacy hyphenated aliases
    case "browser-open":
      return {
        method: "browser.open",
        params: { url: positional[0] },
      };
    case "browser-split":
      return {
        method: "browser.open_split",
        params: {
          url: positional[0],
          direction: flags["direction"] || "right",
        },
      };
    case "browser-navigate":
      return {
        method: "browser.navigate",
        params: {
          surface_id: flags["surface"] || positional[0],
          url: positional[1] || flags["url"],
        },
      };
    case "browser-back":
      return {
        method: "browser.back",
        params: { surface_id: flags["surface"] },
      };
    case "browser-forward":
      return {
        method: "browser.forward",
        params: { surface_id: flags["surface"] },
      };
    case "browser-reload":
      return {
        method: "browser.reload",
        params: { surface_id: flags["surface"] },
      };
    case "browser-url":
      return {
        method: "browser.url",
        params: { surface_id: flags["surface"] },
      };
    case "browser-eval":
      return {
        method: "browser.eval",
        params: {
          surface_id: flags["surface"],
          script: positional[0],
        },
      };
    case "browser-find":
      return {
        method: "browser.find",
        params: {
          surface_id: flags["surface"],
          query: positional[0],
        },
      };
    case "browser-devtools":
      return {
        method: "browser.devtools",
        params: { surface_id: flags["surface"] },
      };
    case "browser-history":
      return { method: "browser.history", params: {} };
    case "browser-clear-history":
      return { method: "browser.clear_history", params: {} };
    case "browser-snapshot":
      return {
        method: "browser.snapshot",
        params: { surface_id: flags["surface"] },
      };
    case "browser-close":
      return {
        method: "browser.close",
        params: { surface_id: flags["surface"] },
      };
    case "list-browsers":
      return { method: "browser.list", params: {} };

    // Cookie commands
    case "browser-cookie-list":
      return {
        method: "browser.cookie_list",
        params: { domain: args[0] || flags["domain"] },
      };
    case "browser-cookie-get":
      return {
        method: "browser.cookie_get",
        params: { url: args[0] || flags["url"] },
      };
    case "browser-cookie-set":
      return {
        method: "browser.cookie_set",
        params: {
          name: args[0] || flags["name"],
          value: args[1] || flags["value"],
          domain: flags["domain"],
          path: flags["path"] || "/",
          expires: ((): number => {
            // parseInt("garbage") returns NaN, parseInt("123abc") silently
            // returns 123 — both are footguns for a security-relevant field.
            // Use Number()+isFinite so bad input becomes 0 (session cookie).
            const raw = flags["expires"];
            if (!raw) return 0;
            const n = Number(raw);
            return Number.isFinite(n) && n > 0 ? Math.floor(n) : 0;
          })(),
          secure: flags["secure"] === "true",
          sameSite: flags["samesite"] || "",
        },
      };
    case "browser-cookie-delete":
      return {
        method: "browser.cookie_delete",
        params: {
          domain: args[0] || flags["domain"],
          name: args[1] || flags["name"],
          path: flags["path"] || "/",
        },
      };
    case "browser-cookie-clear":
      return {
        method: "browser.cookie_clear",
        params: { domain: args[0] || flags["domain"] },
      };
    case "browser-cookie-import": {
      const filePath = args[0] || flags["file"];
      let fileData = "";
      if (filePath) {
        try {
          fileData = require("fs").readFileSync(filePath, "utf-8");
        } catch (e) {
          console.error(`Failed to read file: ${filePath}`);
          process.exit(1);
        }
      }
      return {
        method: "browser.cookie_import",
        params: {
          data: fileData,
          format: flags["format"] || "json",
        },
      };
    }
    case "browser-cookie-export":
      return {
        method: "browser.cookie_export",
        params: { format: flags["format"] || "json" },
      };
    case "browser-cookie-capture":
      return {
        method: "browser.cookie_capture",
        params: { surface_id: flags["surface"] },
      };

    // tmux compat alias
    case "capture-pane":
      return {
        method: "surface.read_text",
        params: {
          surface_id: flags["surface"],
          lines: flags["lines"] ? parseInt(flags["lines"]) : undefined,
          scrollback: flags["scrollback"] === "true",
        },
      };

    // ── System: graceful shutdown ──
    case "shutdown":
      return { method: "system.shutdown", params: {} };

    // ── Sideband panel introspection ──
    case "panels":
    case "list-panels":
      return {
        method: "panel.list",
        params: {
          surface_id:
            flags["surface"] || process.env["HT_SURFACE"] || undefined,
        },
      };

    // ── Script runner ──
    // Spawn a new surface running a command in a target cwd. The returned
    // surface is tagged with the optional scriptKey so the sidebar tracks
    // running/errored state just like a package.json script launch.
    case "run-script":
      return {
        method: "script.run",
        params: {
          cwd: flags["cwd"] || positional[0],
          command: flags["command"] || positional[1] || positional[0],
          workspace_id: flags["workspace"],
          script_key: flags["script-key"] || flags["script_key"],
        },
      };

    // ── Telegram bridge ──
    // Read-side: list chats, dump recent history, show service status.
    // Write-side: send a message to a chat. Default chat resolution:
    //   1. --chat <id>
    //   2. $HT_TELEGRAM_CHAT
    // No implicit "most recent" lookup — keeping the CLI deterministic.
    case "telegram": {
      const sub = positional[0] || "status";
      const chatId =
        flags["chat"] ||
        flags["chat_id"] ||
        process.env["HT_TELEGRAM_CHAT"] ||
        undefined;
      switch (sub) {
        case "status":
          return { method: "telegram.status", params: {} };
        case "restart":
          return { method: "telegram.restart", params: {} };
        case "chats":
        case "list":
          return { method: "telegram.chats", params: {} };
        case "read":
        case "history": {
          // Read shares send's default-chat semantics — handled out-of-band
          // in main() so we can prefetch the chat list when --chat is
          // missing. Same throw pattern as `send` for consistency.
          throw new Error(
            "telegram read: handled by main() — should not reach mapCommand",
          );
        }
        case "send": {
          // Send is handled out-of-band in main() so we can prefetch
          // the default chat list and read piped stdin. mapCommand only
          // ever sees `send` here when something else routes through —
          // throw a helpful error so the failure is loud.
          throw new Error(
            "telegram send: handled by main() — should not reach mapCommand",
          );
        }
        default:
          console.error(`Unknown telegram subcommand: ${sub}`);
          console.error("Supported: status | chats | read | send");
          process.exit(1);
      }
      break;
    }

    // ── Subsystem health ──
    // Aggregated view of every wired subsystem (pty, socket, web
    // mirror, telegram, audits). `ok: true` iff nothing is degraded
    // or errored — disabled subsystems don't count.
    case "health":
      return { method: "system.health", params: {} };

    // ── Agent plan (Plan #09) ──
    // `ht plan set --workspace W [--agent A] --json '[…]'`
    //   — replace the plan with the supplied steps.
    // `ht plan update <stepId> --state done|active|waiting|err`
    //   — patch a single step's state and/or title.
    // `ht plan complete`           — mark every step as done.
    // `ht plan clear`              — drop the plan entirely.
    // `ht plan list`               — print every active plan.
    case "plan": {
      const sub = positional[0] || "list";
      // Workspace is resolved server-side: explicit `--workspace` /
      // `HT_WORKSPACE_ID` wins; otherwise the backend falls back to the
      // workspace that owns `surface_id`. Inside a τ-mux pane HT_SURFACE
      // is auto-set, so `ht plan …` Just Works without flags.
      const workspaceId =
        flags["workspace"] ||
        flags["workspace_id"] ||
        process.env["HT_WORKSPACE_ID"] ||
        undefined;
      const surfaceId =
        flags["surface"] || process.env["HT_SURFACE"] || undefined;
      const agentId =
        flags["agent"] || flags["agent_id"] || undefined;
      const requireScope = (cmd: string): void => {
        if (!workspaceId && !surfaceId) {
          console.error(
            `ht plan ${cmd}: --workspace W is required (or run inside a τ-mux pane so HT_SURFACE is set)`,
          );
          process.exit(1);
        }
      };
      switch (sub) {
        case "list":
          return { method: "plan.list", params: {} };
        case "set": {
          requireScope("set");
          const json = flags["json"];
          if (!json) {
            console.error(
              "ht plan set: --json '<steps>' is required (array of {id,title,state})",
            );
            process.exit(1);
          }
          let steps: unknown;
          try {
            steps = JSON.parse(json);
          } catch (err) {
            console.error(`ht plan set: invalid JSON — ${(err as Error).message}`);
            process.exit(1);
          }
          return {
            method: "plan.set",
            params: {
              workspace_id: workspaceId,
              surface_id: surfaceId,
              agent_id: agentId,
              steps,
            },
          };
        }
        case "update": {
          requireScope("update");
          const stepId = positional[1];
          if (!stepId) {
            console.error("ht plan update: <stepId> positional is required");
            process.exit(1);
          }
          return {
            method: "plan.update",
            params: {
              workspace_id: workspaceId,
              surface_id: surfaceId,
              agent_id: agentId,
              step_id: stepId,
              state: flags["state"],
              title: flags["title"],
            },
          };
        }
        case "complete": {
          requireScope("complete");
          return {
            method: "plan.complete",
            params: {
              workspace_id: workspaceId,
              surface_id: surfaceId,
              agent_id: agentId,
            },
          };
        }
        case "clear": {
          requireScope("clear");
          return {
            method: "plan.clear",
            params: {
              workspace_id: workspaceId,
              surface_id: surfaceId,
              agent_id: agentId,
            },
          };
        }
        default:
          console.error(`Unknown plan subcommand: ${sub}`);
          console.error("Supported: list | set | update | complete | clear");
          process.exit(1);
      }
      break;
    }

    // ── Auto-continue engine (Plan #09 commit C) ──
    // `ht autocontinue status`            — print engine config + paused list.
    // `ht autocontinue audit [--limit N]` — print last N decisions.
    // `ht autocontinue set --engine X
    //   [--dry-run BOOL] [--cooldown MS] [--max N]
    //   [--model NAME] [--api-key-env VAR]` — write settings.
    // `ht autocontinue fire <surface>`    — manual dispatch.
    // `ht autocontinue pause <surface>`   — pause auto-continue for a surface.
    // `ht autocontinue resume <surface>`  — clear the pause.
    case "autocontinue": {
      const sub = positional[0] || "status";
      switch (sub) {
        case "status":
          return { method: "autocontinue.status", params: {} };
        case "audit": {
          const limitRaw = flags["limit"];
          const params: Record<string, unknown> = {};
          if (limitRaw !== undefined) {
            const limit = Number.parseInt(limitRaw, 10);
            if (Number.isFinite(limit)) params["limit"] = limit;
          }
          return { method: "autocontinue.audit", params };
        }
        case "set": {
          const params: Record<string, unknown> = {};
          if (flags["engine"]) params["engine"] = flags["engine"];
          if (flags["dry-run"]) {
            const v = flags["dry-run"].toLowerCase();
            params["dryRun"] = v === "true" || v === "1" || v === "yes";
          }
          if (flags["cooldown"]) {
            const n = Number.parseInt(flags["cooldown"], 10);
            if (Number.isFinite(n)) params["cooldownMs"] = n;
          }
          if (flags["max"]) {
            const n = Number.parseInt(flags["max"], 10);
            if (Number.isFinite(n)) params["maxConsecutive"] = n;
          }
          if (flags["model"]) params["modelName"] = flags["model"];
          if (flags["api-key-env"]) params["modelApiKeyEnv"] = flags["api-key-env"];
          if (Object.keys(params).length === 0) {
            console.error(
              "ht autocontinue set: pass at least one of --engine, --dry-run, --cooldown, --max, --model, --api-key-env",
            );
            process.exit(1);
          }
          return { method: "autocontinue.set", params };
        }
        case "fire": {
          const surfaceId = positional[1];
          if (!surfaceId) {
            console.error("ht autocontinue fire: <surface> positional is required");
            process.exit(1);
          }
          return {
            method: "autocontinue.fire",
            params: { surface_id: surfaceId },
          };
        }
        case "pause": {
          const surfaceId = positional[1];
          if (!surfaceId) {
            console.error("ht autocontinue pause: <surface> positional is required");
            process.exit(1);
          }
          return {
            method: "autocontinue.pause",
            params: { surface_id: surfaceId },
          };
        }
        case "resume": {
          const surfaceId = positional[1];
          if (!surfaceId) {
            console.error("ht autocontinue resume: <surface> positional is required");
            process.exit(1);
          }
          return {
            method: "autocontinue.resume",
            params: { surface_id: surfaceId },
          };
        }
        default:
          console.error(`Unknown autocontinue subcommand: ${sub}`);
          console.error("Supported: status | audit | set | fire | pause | resume");
          process.exit(1);
      }
      break;
    }

    // ── Startup audits ──
    // `audit list`   — return cached results (the running app
    //                  populates this once at boot via runAudits).
    // `audit run`    — rerun every audit; refresh the cache.
    // `audit fix`    — apply the named audit's fix and rerun it.
    case "audit": {
      const sub = positional[0] || "list";
      switch (sub) {
        case "list":
          return { method: "audit.list", params: {} };
        case "run":
          return { method: "audit.run", params: {} };
        case "fix":
          return { method: "audit.fix", params: { id: positional[1] } };
        default:
          console.error(`Unknown audit subcommand: ${sub}`);
          console.error("Supported: list | run | fix <id>");
          process.exit(1);
      }
      break;
    }

    // ── Agent panes ──
    case "agent": {
      const sub = positional[0] || "identify";
      switch (sub) {
        case "new":
        case "create":
          return { method: "agent.create", params: {} };
        case "split":
        case "new-split":
          return {
            method: "agent.create_split",
            params: { direction: positional[1] || "horizontal" },
          };
        case "list":
          return { method: "agent.list", params: {} };
        case "count":
          return { method: "agent.count", params: {} };
        case "close":
          return {
            method: "agent.close",
            params: {
              agent_id: flags["agent"] || positional[1],
              surface_id: flags["surface"] || positional[1],
            },
          };
        default:
          console.error(`Unknown agent subcommand: ${sub}`);
          console.error(
            "Supported: new | split | list | count | close",
          );
          process.exit(1);
      }
      break;
    }

    default:
      console.error(`Unknown command: ${command}`);
      console.error('Run "ht --help" for usage.');
      process.exit(1);
  }
}

/** One JSON-RPC round-trip over the unix socket. Resolves to the
 *  decoded `result`, rejects on transport failure / server error /
 *  timeout. Single-shot — opens, sends, closes on first response.
 *
 *  `timeoutMs` defaults to 5000 (the original watchdog so a stuck
 *  app doesn't hang the CLI forever). Plan #10's `agent.ask_user`
 *  RPC is long-pending — pass 0 to disable the watchdog and wait
 *  for the bun-side response. */
function runRpc(
  method: string,
  params: Record<string, unknown>,
  timeoutMs: number = 5000,
): Promise<unknown> {
  return new Promise((resolve, reject) => {
    const payload = JSON.stringify({ id: "1", method, params }) + "\n";
    const sock = connect(SOCKET_PATH);
    let buf = "";
    let done = false;
    const timer =
      timeoutMs > 0
        ? setTimeout(() => {
            if (done) return;
            done = true;
            sock.end();
            reject(
              new Error(
                `no response from HyperTerm within ${timeoutMs}ms (method=${method}). The app may be unresponsive. Socket: ${SOCKET_PATH}`,
              ),
            );
          }, timeoutMs)
        : null;

    sock.on("connect", () => sock.write(payload));
    sock.on("data", (chunk) => {
      buf += chunk.toString();
      const lines = buf.split("\n");
      for (let i = 0; i < lines.length - 1; i++) {
        const line = lines[i].trim();
        if (!line) continue;
        try {
          const res = JSON.parse(line);
          if (done) return;
          done = true;
          if (timer) clearTimeout(timer);
          sock.end();
          if (res.error) reject(new Error(String(res.error)));
          else resolve(res.result);
          return;
        } catch {
          /* unparseable line — keep buffering */
        }
      }
      buf = lines[lines.length - 1];
    });
    sock.on("error", (err: Error & { code?: string }) => {
      if (done) return;
      done = true;
      clearTimeout(timer);
      reject(err);
    });
  });
}

/** Resolve the message body for `ht telegram send`. Joins all
 *  positional args after `send`; if empty and stdin is piped, slurps
 *  the entire piped payload. Trailing newlines from typical pipelines
 *  (`echo "x" | ht telegram send`) are trimmed so the chat doesn't
 *  show a blank trailing line. */
function resolveSendText(): string {
  const inline = positional.slice(1).join(" ");
  if (inline) return unescapeText(inline);
  if (!process.stdin.isTTY) {
    try {
      const piped = readFileSync(0, "utf-8");
      return piped.replace(/\n+$/, "");
    } catch {
      return "";
    }
  }
  return "";
}

/** Default-chat fallback: when no --chat / HT_TELEGRAM_CHAT is set,
 *  ask the running app for its chat list and use the most-recently-
 *  active one. Returns null when no chats exist yet (caller errors out). */
async function resolveDefaultChatId(): Promise<{
  id: string;
  name?: string;
} | null> {
  try {
    const result = (await runRpc("telegram.chats", {})) as
      | { chats?: Array<{ id: string; name?: string }> }
      | undefined;
    const first = result?.chats?.[0];
    if (!first) return null;
    return { id: first.id, name: first.name };
  } catch {
    return null;
  }
}

/** `ht doctor` — diagnostic kitchen sink. Prints the resolved socket
 *  path, whether `HT_SOCKET_PATH` was explicit, socket reachability,
 *  app version, log file path, and the local Bun runtime version.
 *
 *  This is the first command users run when "the CLI doesn't seem to
 *  do anything"; it's also the canonical "paste this output in your
 *  bug report" command. Each line is prefixed with a stable key so
 *  scripts can grep by `^socket_path:` etc. */
async function runDoctor(): Promise<void> {
  const envSet = !!process.env["HT_SOCKET_PATH"];
  console.log(`socket_path:        ${SOCKET_PATH}`);
  console.log(
    `HT_SOCKET_PATH:     ${envSet ? "set" : "unset (using default)"}`,
  );
  console.log(`bun_version:        ${typeof Bun !== "undefined" ? Bun.version : "n/a"}`);

  // Single round-trip — system.identify includes socket_path + log_path.
  let identify: {
    focused_surface?: unknown;
    active_workspace?: unknown;
    socket_path?: unknown;
    log_path?: unknown;
  } | null = null;
  try {
    identify = (await runRpc("system.identify", {})) as typeof identify;
    console.log(`socket_reachable:   yes`);
  } catch (err) {
    console.log(
      `socket_reachable:   no (${(err as Error & { code?: string }).code ?? (err as Error).message})`,
    );
  }

  if (identify) {
    console.log(
      `socket_path_bound:  ${String(identify.socket_path ?? "(unknown)")}`,
    );
    console.log(`log_path:           ${String(identify.log_path ?? "(none)")}`);
    console.log(
      `focused_surface:    ${String(identify.focused_surface ?? "(none)")}`,
    );
    console.log(
      `active_workspace:   ${String(identify.active_workspace ?? "(none)")}`,
    );

    // Detect drift: the CLI's resolved path vs. the path the running
    // app is actually bound to. If they differ, the user almost
    // certainly has a stale shell with no `HT_SOCKET_PATH` export.
    if (
      typeof identify.socket_path === "string" &&
      identify.socket_path !== SOCKET_PATH
    ) {
      console.log("");
      console.log(
        `warning: CLI socket path (${SOCKET_PATH}) differs from app's bound path (${identify.socket_path}).`,
      );
      console.log(
        `         export HT_SOCKET_PATH="${identify.socket_path}" and reopen this shell.`,
      );
    }
  }

  let version: string | null = null;
  try {
    version = (await runRpc("system.version", {})) as string;
    console.log(`app_version:        ${version}`);
  } catch {
    // Already covered by socket_reachable above.
  }
}

/** `ht logs` — print today's log file path. With `--tail`, exec
 *  `tail -F` on it and inherit stdio so the user can stream the file
 *  in their existing terminal. */
async function runLogs(): Promise<void> {
  let logPath: string | null = null;
  try {
    const identify = (await runRpc("system.identify", {})) as {
      log_path?: unknown;
    };
    if (typeof identify.log_path === "string" && identify.log_path) {
      logPath = identify.log_path;
    }
  } catch {
    // App not running. We can still tell the user where logs *would* be
    // for the default config dir; rederiving the exact path would
    // duplicate logger.ts's logic, so just point at the directory.
    console.error("HyperTerm Canvas is not running.");
    console.error(`Default log directory: ~/Library/Logs/tau-mux/`);
    process.exit(1);
  }

  if (!logPath) {
    console.error(
      "log file disabled (the app could not open its log directory).",
    );
    process.exit(1);
  }

  if (flags["tail"] === "true" || flags["t"] === "true") {
    const tail = Bun.spawn(["tail", "-F", logPath], {
      stdout: "inherit",
      stderr: "inherit",
    });
    process.on("SIGINT", () => tail.kill());
    await tail.exited;
    return;
  }

  console.log(logPath);
}

/** `ht ask` (Plan #10) — blocking question to the human user.
 *  Subcommands:
 *    ask <kind> [--title T] [--body B] [--choices …] [--default V] [--timeout MS]
 *      → fires `agent.ask_user`, blocks until the matching answer
 *        lands. Prints the chosen value on stdout; exits non-zero on
 *        cancel/timeout with a stderr reason.
 *    ask pending [--surface S]
 *      → list pending requests.
 *    ask answer <id> <value>
 *      → resolve a pending request from a sibling shell. Returns
 *        `(ok)` on success, `(no such id)` otherwise.
 *    ask cancel <id> [--reason …]
 *      → cancel a pending request. */
async function runAsk(): Promise<void> {
  const sub = positional[0] || "";
  const isKnownKind =
    sub === "yesno" ||
    sub === "choice" ||
    sub === "text" ||
    sub === "confirm-command";
  if (sub === "pending") {
    return runAskPending();
  }
  if (sub === "answer") {
    return runAskAnswer();
  }
  if (sub === "cancel") {
    return runAskCancel();
  }
  if (isKnownKind) {
    return runAskQuestion(sub);
  }
  console.error(
    "Usage: ht ask <yesno|choice|text|confirm-command> [--title T] [--body B] [--choices a,b,c] [--default V] [--timeout MS]",
  );
  console.error("       ht ask pending [--surface S]");
  console.error("       ht ask answer <id> <value>");
  console.error("       ht ask cancel <id> [--reason …]");
  process.exit(1);
}

async function runAskQuestion(kind: string): Promise<void> {
  const surfaceId =
    flags["surface"] || process.env["HT_SURFACE"] || undefined;
  if (!surfaceId) {
    console.error(
      "ht ask: --surface S is required (or run inside a τ-mux pane so HT_SURFACE is set)",
    );
    process.exit(1);
  }
  const title = flags["title"] || positional[1] || "";
  if (!title) {
    console.error("ht ask: --title T is required");
    process.exit(1);
  }
  const body = flags["body"];
  const choicesRaw = flags["choices"];
  const choices =
    kind === "choice" && choicesRaw
      ? choicesRaw.split(",").map((s) => {
          const [id, label] = s.split(":");
          const cleanId = (id ?? "").trim();
          return {
            id: cleanId,
            label: (label ?? cleanId).trim(),
          };
        })
      : undefined;
  if (kind === "choice" && (!choices || choices.length === 0)) {
    console.error(
      "ht ask choice: --choices a,b,c (or 'id:label,id:label') is required",
    );
    process.exit(1);
  }
  const timeoutRaw = flags["timeout"];
  const timeoutMs =
    typeof timeoutRaw === "string" && timeoutRaw.length > 0
      ? Math.max(0, Math.floor(Number(timeoutRaw)))
      : undefined;
  // The wire timeout is whatever the bun-side queue enforces; we
  // disable the CLI's runRpc watchdog so the long-pending RPC can
  // sit until the user answers.
  const params: Record<string, unknown> = {
    surface_id: surfaceId,
    kind,
    title,
  };
  if (body) params["body"] = body;
  if (choices) params["choices"] = choices;
  if (flags["default"]) params["default"] = flags["default"];
  if (typeof timeoutMs === "number") params["timeout_ms"] = timeoutMs;
  if (flags["unsafe"] === "true") params["unsafe"] = true;
  if (flags["agent"]) params["agent_id"] = flags["agent"];

  let result: { request_id: string; action: string; value?: string; reason?: string };
  try {
    result = (await runRpc("agent.ask_user", params, 0)) as typeof result;
  } catch (err) {
    console.error(`ht ask: ${(err as Error).message}`);
    process.exit(1);
  }
  if (result.action === "ok" && typeof result.value === "string") {
    console.log(result.value);
    return;
  }
  if (result.action === "timeout") {
    console.error("ht ask: timed out");
    process.exit(2);
  }
  // cancel
  if (result.reason) console.error(`ht ask: cancelled — ${result.reason}`);
  else console.error("ht ask: cancelled");
  process.exit(3);
}

async function runAskPending(): Promise<void> {
  const params: Record<string, unknown> = {};
  if (flags["surface"]) params["surface_id"] = flags["surface"];
  const result = (await runRpc("agent.ask_pending", params)) as {
    pending: Array<{
      request_id: string;
      surface_id: string;
      kind: string;
      title: string;
      body?: string;
    }>;
  };
  if (!result.pending || result.pending.length === 0) {
    console.log("(no pending questions)");
    return;
  }
  for (const r of result.pending) {
    const head = `${r.request_id.padEnd(10)} ${r.kind.padEnd(16)} ${r.surface_id}`;
    console.log(`${head}  ${r.title}`);
    if (r.body) console.log(`   ${r.body.split("\n").join("\n   ")}`);
  }
}

async function runAskAnswer(): Promise<void> {
  const id = positional[1];
  const value = positional[2];
  if (!id || value === undefined) {
    console.error("ht ask answer: <id> <value> are required");
    process.exit(1);
  }
  const result = (await runRpc("agent.ask_answer", {
    request_id: id,
    value,
  })) as { resolved: boolean };
  console.log(result.resolved ? "ok" : "(no such id — already resolved or unknown)");
  if (!result.resolved) process.exit(1);
}

async function runAskCancel(): Promise<void> {
  const id = positional[1];
  if (!id) {
    console.error("ht ask cancel: <id> is required");
    process.exit(1);
  }
  const params: Record<string, unknown> = { request_id: id };
  if (flags["reason"]) params["reason"] = flags["reason"];
  const result = (await runRpc("agent.ask_cancel", params)) as {
    resolved: boolean;
  };
  console.log(result.resolved ? "ok (cancelled)" : "(no such id)");
  if (!result.resolved) process.exit(1);
}

async function runTelegramRead(): Promise<void> {
  let chatId =
    flags["chat"] ||
    flags["chat_id"] ||
    process.env["HT_TELEGRAM_CHAT"] ||
    "";
  if (!chatId) {
    const fallback = await resolveDefaultChatId();
    if (!fallback) {
      console.error(
        "telegram read: no chat id (use --chat <id>, set HT_TELEGRAM_CHAT, or open a chat with the bot first)",
      );
      process.exit(1);
    }
    chatId = fallback.id;
    console.error(
      `telegram read: defaulting to chat ${chatId}${
        fallback.name ? ` (${fallback.name})` : ""
      }`,
    );
  }
  const limitRaw = flags["limit"];
  const limit = limitRaw ? parseInt(limitRaw, 10) : 20;
  try {
    const res = await runRpc("telegram.history", { chat_id: chatId, limit });
    formatOutput(res);
  } catch (err) {
    console.error(`Error: ${(err as Error).message}`);
    process.exit(1);
  }
}

async function runTelegramSend(): Promise<void> {
  let chatId =
    flags["chat"] ||
    flags["chat_id"] ||
    process.env["HT_TELEGRAM_CHAT"] ||
    "";
  const text = resolveSendText();
  if (!text) {
    console.error("telegram send: missing text (positional, or piped stdin)");
    process.exit(1);
  }
  if (!chatId) {
    const fallback = await resolveDefaultChatId();
    if (!fallback) {
      console.error(
        "telegram send: no chat id (use --chat <id>, set HT_TELEGRAM_CHAT, or open a chat with the bot first)",
      );
      process.exit(1);
    }
    chatId = fallback.id;
    console.error(
      `telegram send: defaulting to chat ${chatId}${
        fallback.name ? ` (${fallback.name})` : ""
      }`,
    );
  }
  try {
    const res = await runRpc("telegram.send", { chat_id: chatId, text });
    formatOutput(res);
  } catch (err) {
    console.error(`Error: ${(err as Error).message}`);
    process.exit(1);
  }
}

async function main(): Promise<void> {
  // Telegram send needs a multi-step flow (stdin / default-chat
  // resolution) that the regular single-RPC pipeline can't model.
  // Intercept it before mapCommand runs.
  if (command === "telegram" && positional[0] === "send") {
    await runTelegramSend();
    return;
  }
  if (
    command === "telegram" &&
    (positional[0] === "read" || positional[0] === "history")
  ) {
    await runTelegramRead();
    return;
  }

  // `doctor` / `logs` are diagnostic commands that combine multiple
  // signals (env, RPC, filesystem, child process). Intercept before
  // mapCommand because they don't map cleanly to a single RPC call.
  if (command === "doctor") {
    await runDoctor();
    return;
  }
  if (command === "logs") {
    await runLogs();
    return;
  }
  // `ask` blocks indefinitely (or until --timeout) waiting for a
  // human to answer via a sibling `ht ask answer …` / future panel
  // / Telegram. Intercept so we can disable the runRpc watchdog.
  if (command === "ask") {
    await runAsk();
    return;
  }

  const rpcCall = mapCommand();
  try {
    const result = await runRpc(rpcCall.method, rpcCall.params);
    formatOutput(result);
  } catch (err) {
    const e = err as Error & { code?: string };
    if (e.code === "ENOENT" || e.code === "ECONNREFUSED") {
      console.error("HyperTerm Canvas is not running.");
      console.error(`Socket not found: ${SOCKET_PATH}`);
    } else {
      console.error(`Error: ${e.message}`);
    }
    process.exit(1);
  }
}

void main();

function formatOutput(result: unknown): void {
  if (result === "PONG") {
    console.log("PONG");
    return;
  }
  if (typeof result === "string") {
    console.log(result);
    return;
  }
  if (flags["json"] === "true" || flags["j"] === "true") {
    console.log(JSON.stringify(result, null, 2));
    return;
  }
  // Metadata-derived commands share one RPC method; format per command.
  if (
    command === "cwd" ||
    command === "ps" ||
    command === "ports" ||
    command === "git" ||
    command === "metadata"
  ) {
    formatMetadata(result, command);
    return;
  }
  if (command === "open" && result && typeof result === "object") {
    const { url } = result as { url: string };
    if (url) {
      console.log(`Opening ${url}`);
      return;
    }
  }
  if (command === "kill" && result && typeof result === "object") {
    const { pid, port, signal } = result as {
      pid: number;
      port: number;
      signal: string;
    };
    console.log(`Sent ${signal} to pid ${pid} (port :${port})`);
    return;
  }
  if (command === "telegram" && result && typeof result === "object") {
    formatTelegram(result);
    return;
  }
  if (command === "audit") {
    formatAudit(result);
    return;
  }
  if (command === "health") {
    formatHealth(result);
    return;
  }
  if (command === "plan") {
    formatPlan(result);
    return;
  }
  if (command === "autocontinue") {
    formatAutoContinue(positional[0] || "status", result);
    return;
  }
  if (command === "screenshot" && result && typeof result === "object") {
    const { path, cropped, surface_id } = result as {
      path: string;
      cropped?: boolean;
      surface_id?: string;
    };
    if (cropped && surface_id) {
      console.log(`${path}  (cropped to ${surface_id})`);
    } else {
      console.log(path);
    }
    return;
  }
  // Format specific types
  if (Array.isArray(result)) {
    if (result.length === 0) {
      console.log("(none)");
      return;
    }
    // Workspace list
    if (result[0]?.name && result[0]?.id) {
      for (const item of result) {
        const marker = item.active ? "* " : "  ";
        const extra = item.active ? " [selected]" : "";
        console.log(`${marker}${item.id}  ${item.name}${extra}`);
      }
      return;
    }
  }
  // Tree output
  if (Array.isArray(result) && result[0]?.workspace) {
    for (const ws of result) {
      const marker = ws.active ? "* " : "  ";
      console.log(`${marker}${ws.workspace} "${ws.name}"`);
      for (const s of ws.surfaces || []) {
        const focus = s.focused ? " [focused]" : "";
        console.log(`    ${s.id} pid=${s.pid} "${s.title}"${focus}`);
      }
    }
    return;
  }
  // Default: JSON
  console.log(JSON.stringify(result, null, 2));
}

interface MetadataSnapshot {
  pid: number;
  foregroundPid: number;
  cwd: string;
  tree: { pid: number; ppid: number; command: string }[];
  listeningPorts: {
    pid: number;
    port: number;
    proto: string;
    address: string;
  }[];
  git: {
    branch: string;
    head: string;
    upstream: string;
    ahead: number;
    behind: number;
    staged: number;
    unstaged: number;
    untracked: number;
    conflicts: number;
    insertions: number;
    deletions: number;
    detached: boolean;
  } | null;
  updatedAt: number;
}

function formatMetadata(
  result: unknown,
  cmd: "cwd" | "ps" | "ports" | "git" | "metadata",
): void {
  if (!result || typeof result !== "object") {
    console.error("No metadata available (surface not found or not polled yet).");
    process.exit(1);
  }
  const meta = result as MetadataSnapshot;

  if (cmd === "cwd") {
    console.log(meta.cwd || "");
    return;
  }

  if (cmd === "ps") {
    const fg = meta.foregroundPid;
    console.log("  PID  PPID  COMMAND");
    for (const node of meta.tree) {
      const marker = node.pid === fg ? "* " : "  ";
      console.log(
        `${marker}${String(node.pid).padStart(5)} ${String(node.ppid).padStart(5)}  ${node.command}`,
      );
    }
    return;
  }

  if (cmd === "ports") {
    if (meta.listeningPorts.length === 0) {
      console.log("(no listening ports)");
      return;
    }
    const byPid = new Map<number, string>();
    for (const n of meta.tree) byPid.set(n.pid, n.command);
    console.log("PORT   PROTO  ADDRESS          PID    COMMAND");
    for (const p of meta.listeningPorts) {
      console.log(
        `${String(p.port).padEnd(6)} ${p.proto.padEnd(6)} ${p.address.padEnd(16)} ${String(p.pid).padEnd(6)} ${byPid.get(p.pid) ?? ""}`,
      );
    }
    return;
  }

  if (cmd === "git") {
    if (!meta.git) {
      console.log("(not a git repo)");
      return;
    }
    const g = meta.git;
    console.log(`branch:    ${g.branch}${g.head ? " @ " + g.head : ""}`);
    if (g.upstream) {
      const ab: string[] = [];
      if (g.ahead > 0) ab.push(`ahead ${g.ahead}`);
      if (g.behind > 0) ab.push(`behind ${g.behind}`);
      console.log(
        `upstream:  ${g.upstream}${ab.length ? " (" + ab.join(", ") + ")" : ""}`,
      );
    }
    console.log(
      `files:     ${g.staged} staged, ${g.unstaged} unstaged, ${g.untracked} untracked${g.conflicts ? `, ${g.conflicts} conflicts` : ""}`,
    );
    console.log(`diff HEAD: +${g.insertions} -${g.deletions}`);
    return;
  }

  // "metadata" — pretty summary
  const fgNode = meta.tree.find((n) => n.pid === meta.foregroundPid);
  console.log(`pid        ${meta.pid}`);
  console.log(`fg pid     ${meta.foregroundPid}`);
  console.log(`fg command ${fgNode?.command ?? ""}`);
  console.log(`cwd        ${meta.cwd}`);
  if (meta.git) {
    const dirty =
      meta.git.staged + meta.git.unstaged + meta.git.untracked + meta.git.conflicts;
    console.log(
      `git        ${meta.git.branch}${dirty ? ` (${dirty} dirty)` : ""}`,
    );
  }
  console.log(`tree       ${meta.tree.length} process(es)`);
  console.log(`ports      ${meta.listeningPorts.length} listener(s)`);
}

function formatTelegram(result: object): void {
  // `telegram.send` returns the bare wire message (id, direction, text, …).
  // Other read methods wrap their payload in { messages | chats | status }.
  const obj = result as Record<string, unknown>;

  if (Array.isArray(obj["messages"])) {
    const messages = obj["messages"] as Array<{
      id: number;
      direction: "in" | "out";
      text: string;
      ts: number;
      fromName: string | null;
    }>;
    if (messages.length === 0) {
      console.log("(no messages)");
      return;
    }
    for (const m of messages) {
      const d = new Date(m.ts);
      const hh = String(d.getHours()).padStart(2, "0");
      const mm = String(d.getMinutes()).padStart(2, "0");
      const who = m.direction === "out" ? "You" : (m.fromName ?? "Them");
      // Indent multi-line bodies under the meta line so `grep "^\["`
      // still finds one row per message.
      const [first, ...rest] = m.text.split("\n");
      console.log(`[${hh}:${mm}] ${who}: ${first}`);
      for (const line of rest) console.log(`         ${line}`);
    }
    return;
  }

  if (Array.isArray(obj["chats"])) {
    const chats = obj["chats"] as Array<{
      id: string;
      name: string;
      lastSeen: number;
    }>;
    if (chats.length === 0) {
      console.log("(no chats yet)");
      return;
    }
    for (const c of chats) {
      console.log(
        `${c.id}\t${c.name}\t(last seen ${formatRelative(c.lastSeen)})`,
      );
    }
    return;
  }

  if (obj["status"] && typeof obj["status"] === "object") {
    const s = obj["status"] as { state: string; error?: string };
    if (s.error) {
      console.log(`${s.state}: ${s.error}`);
    } else {
      console.log(s.state);
    }
    return;
  }

  // Outbound `telegram.send` reply — single wire message.
  if (typeof obj["id"] === "number" && typeof obj["text"] === "string") {
    const ts = (obj["ts"] as number) ?? Date.now();
    const d = new Date(ts);
    const hh = String(d.getHours()).padStart(2, "0");
    const mm = String(d.getMinutes()).padStart(2, "0");
    console.log(`sent [${hh}:${mm}]  ${String(obj["text"])}`);
    return;
  }

  console.log(JSON.stringify(result, null, 2));
}

interface PlanWireStep {
  id: string;
  title: string;
  state: "done" | "active" | "waiting" | "err";
}
interface PlanWire {
  workspaceId: string;
  agentId?: string;
  steps: PlanWireStep[];
  updatedAt: number;
}

/** Pretty-print plan results. `plan list` returns `{plans: [...]}`;
 *  `plan set / update / complete` return a single Plan or null;
 *  `plan clear` returns `{removed: boolean}`. Each path goes through
 *  here so the CLI's output is uniform across subcommands. */
function formatPlan(result: unknown): void {
  if (!result) {
    console.log("(no plan)");
    return;
  }
  if (typeof result === "object" && "removed" in (result as object)) {
    const r = result as { removed: boolean };
    console.log(r.removed ? "ok (plan removed)" : "(no plan to clear)");
    return;
  }
  if (typeof result === "object" && "plans" in (result as object)) {
    const list = ((result as { plans: PlanWire[] }).plans ?? []) as PlanWire[];
    if (list.length === 0) {
      console.log("(no plans)");
      return;
    }
    for (let i = 0; i < list.length; i++) {
      if (i > 0) console.log("");
      printPlan(list[i]!);
    }
    return;
  }
  printPlan(result as PlanWire);
}

function printPlan(plan: PlanWire): void {
  const useColor = process.stdout.isTTY;
  const head = plan.agentId
    ? `${plan.workspaceId}  ${plan.agentId}`
    : plan.workspaceId;
  console.log(head);
  for (const step of plan.steps) {
    const marker =
      step.state === "done"
        ? useColor ? "\x1b[32m✓\x1b[0m" : "✓"
        : step.state === "active"
          ? useColor ? "\x1b[36m●\x1b[0m" : "●"
          : step.state === "err"
            ? useColor ? "\x1b[31m✗\x1b[0m" : "✗"
            : useColor ? "\x1b[90m○\x1b[0m" : "○";
    console.log(`  ${marker}  ${step.id.padEnd(8)} ${step.title}`);
  }
}

interface AutoContinueAuditWire {
  at: number;
  surfaceId: string;
  agentId?: string;
  outcome: "fired" | "dry-run" | "skipped" | "paused" | "resumed";
  reason: string;
  engine: "off" | "heuristic" | "model" | "hybrid";
  modelConsulted: boolean;
}

interface AutoContinueStatusWire {
  engine: "off" | "heuristic" | "model" | "hybrid";
  dryRun: boolean;
  cooldownMs: number;
  maxConsecutive: number;
  modelProvider: string;
  modelName: string;
  modelApiKeyEnv: string;
  paused: string[];
}

/** Pretty-print every `autocontinue.*` result. The CLI funnels every
 *  subcommand through this so the output stays readable for humans
 *  while `--json` still gives scripts a stable shape. */
function formatAutoContinue(sub: string, result: unknown): void {
  if (!result || typeof result !== "object") {
    console.log("(none)");
    return;
  }
  const obj = result as Record<string, unknown>;
  if (sub === "status") {
    const s = obj as unknown as AutoContinueStatusWire;
    console.log(`engine          ${s.engine}`);
    console.log(`dryRun          ${s.dryRun}`);
    console.log(`cooldownMs      ${s.cooldownMs}`);
    console.log(`maxConsecutive  ${s.maxConsecutive}`);
    console.log(`model           ${s.modelProvider}/${s.modelName}`);
    console.log(`apiKeyEnv       ${s.modelApiKeyEnv}`);
    if (s.paused && s.paused.length > 0) {
      console.log(`paused          ${s.paused.join(", ")}`);
    } else {
      console.log("paused          (none)");
    }
    return;
  }
  if (sub === "audit") {
    const audit = (obj["audit"] ?? []) as AutoContinueAuditWire[];
    if (audit.length === 0) {
      console.log("(no decisions)");
      return;
    }
    const useColor = process.stdout.isTTY;
    for (const e of audit) {
      const time = new Date(e.at).toISOString().slice(11, 19);
      const tag =
        e.outcome === "fired"
          ? useColor ? "\x1b[32mfired\x1b[0m   " : "fired   "
          : e.outcome === "dry-run"
            ? useColor ? "\x1b[33mdry-run\x1b[0m " : "dry-run "
            : e.outcome === "paused"
              ? useColor ? "\x1b[35mpaused\x1b[0m  " : "paused  "
              : e.outcome === "resumed"
                ? useColor ? "\x1b[36mresumed\x1b[0m " : "resumed "
                : useColor ? "\x1b[90mskipped\x1b[0m " : "skipped ";
      const m = e.modelConsulted ? " (model)" : "";
      console.log(`${time}  ${tag}  ${e.surfaceId}  ${e.reason}${m}`);
    }
    return;
  }
  if (sub === "set") {
    const ac = obj["autoContinue"] as unknown as AutoContinueStatusWire;
    if (ac) {
      console.log(`ok — engine=${ac.engine} dryRun=${ac.dryRun} cooldown=${ac.cooldownMs}ms max=${ac.maxConsecutive}`);
    } else {
      console.log("ok");
    }
    return;
  }
  if (sub === "pause" || sub === "resume") {
    const paused = (obj["paused"] ?? []) as string[];
    if (paused.length > 0) {
      console.log(`ok — paused: ${paused.join(", ")}`);
    } else {
      console.log("ok — no surfaces paused");
    }
    return;
  }
  if (sub === "fire") {
    const out = obj["outcome"] as Record<string, unknown> | undefined;
    if (!out) {
      console.log("(no outcome)");
      return;
    }
    const kind = out["kind"] as string;
    const reason =
      kind === "skipped"
        ? (out["reason"] as string)
        : ((out["decision"] as Record<string, unknown> | undefined)?.[
            "reason"
          ] as string | undefined) || kind;
    console.log(`${kind}  ${reason ?? ""}`);
    return;
  }
  console.log(JSON.stringify(result, null, 2));
}

interface HealthEntry {
  id: string;
  severity: "ok" | "degraded" | "error" | "disabled";
  message: string;
  updatedAt: number;
}

/** Pretty-print the `{ok, entries[]}` health snapshot. ANSI markers
 *  on a TTY; a one-line "OK · N subsystem(s)" summary up top so a
 *  glance over `ht health` is enough on green builds. */
function formatHealth(result: unknown): void {
  if (!result || typeof result !== "object") {
    console.log(JSON.stringify(result, null, 2));
    return;
  }
  const r = result as { ok: boolean; entries: HealthEntry[] };
  const useColor = process.stdout.isTTY;
  const okMark = useColor ? "\x1b[32m✓\x1b[0m" : "✓";
  const failMark = useColor ? "\x1b[31m✗\x1b[0m" : "✗";
  const summary = r.ok ? `${okMark} OK` : `${failMark} DEGRADED`;
  console.log(`${summary} · ${r.entries.length} subsystem(s)`);
  if (r.entries.length === 0) return;
  for (const e of r.entries) {
    const marker =
      e.severity === "ok"
        ? useColor ? "\x1b[32m●\x1b[0m" : "●"
        : e.severity === "disabled"
          ? useColor ? "\x1b[90m○\x1b[0m" : "○"
          : e.severity === "degraded"
            ? useColor ? "\x1b[33m◐\x1b[0m" : "◐"
            : useColor ? "\x1b[31m✗\x1b[0m" : "✗";
    console.log(
      `${marker}  ${e.id.padEnd(20)} [${e.severity.padEnd(8)}] ${e.message}`,
    );
  }
}

interface AuditWireResult {
  id: string;
  ok: boolean;
  severity: "info" | "warn" | "err";
  message: string;
  fixAvailable?: boolean;
  fixLabel?: string;
}

/** Pretty-print audit results. Single result (from `audit fix`) and
 *  list response (from `audit list / run`) both go through here so
 *  the CLI's output is uniform. */
function formatAudit(result: unknown): void {
  if (Array.isArray(result)) {
    if (result.length === 0) {
      console.log("(no audits registered — set auditsGitUserNameExpected to enable)");
      return;
    }
    for (const r of result as AuditWireResult[]) {
      printAuditLine(r);
    }
    return;
  }
  if (result && typeof result === "object") {
    printAuditLine(result as AuditWireResult);
    return;
  }
  console.log(JSON.stringify(result, null, 2));
}

function printAuditLine(r: AuditWireResult): void {
  // ANSI: green ✓ / yellow ⚠ / red ✗  (TTY only).
  const useColor = process.stdout.isTTY;
  const marker = r.ok
    ? useColor ? "\x1b[32m✓\x1b[0m" : "✓"
    : r.severity === "err"
      ? useColor ? "\x1b[31m✗\x1b[0m" : "✗"
      : useColor ? "\x1b[33m⚠\x1b[0m" : "⚠";
  const head = `${marker}  ${r.id.padEnd(20)} ${r.message}`;
  console.log(head);
  if (!r.ok && r.fixAvailable && r.fixLabel) {
    console.log(`   fix: ${r.fixLabel}  (run: ht audit fix ${r.id})`);
  }
}

function formatRelative(ts: number): string {
  const diffSec = Math.max(0, Math.floor((Date.now() - ts) / 1000));
  if (diffSec < 60) return `${diffSec}s ago`;
  if (diffSec < 3600) return `${Math.floor(diffSec / 60)}m ago`;
  if (diffSec < 86400) return `${Math.floor(diffSec / 3600)}h ago`;
  return `${Math.floor(diffSec / 86400)}d ago`;
}

function printHelp(): void {
  console.log(`ht — HyperTerm Canvas CLI

Usage: ht <command> [options]

System:
  ping                              Check if HyperTerm is running
  version                           Show version
  identify                          Show focused workspace/surface
  capabilities                      List available methods
  tree                              Show workspace/pane/surface tree

Workspaces:
  list-workspaces                   List all workspaces
  current-workspace                 Get active workspace
  new-workspace [--name N] [--cwd P] Create new workspace
  select-workspace --workspace W    Switch to workspace
  close-workspace --workspace W     Close workspace
  rename-workspace [--workspace W] NAME  Rename workspace
  next-workspace                    Switch to next
  previous-workspace                Switch to previous

Surfaces & Panes:
  list-surfaces                     List all surfaces
  new-split <right|down|left|up>    Split focused pane
  close-surface [--surface S]       Close surface
  focus-surface --surface S         Focus surface
  list-panes                        List panes

I/O:
  send [--surface S] "text"         Send text to terminal.
                                    Escapes: \\n and \\r both send carriage
                                    return (the terminal expects \\r for Enter,
                                    not \\n). \\t = tab, \\x1b = ESC, \\\\ = literal \\.
  send-key [--surface S] <key>      Send key (enter|tab|escape|...)
  read-screen [--surface S] [--lines N]  Read terminal content
  screenshot [--surface S] [--output PATH] [--full-window]
                                    Capture a PNG of the surface (or the
                                    whole app window with --full-window).
                                    macOS only; prints the resulting path.

Sidebar:
  set-status <key> <value> [--icon I] [--color #hex]
  clear-status <key>
  set-progress <0.0-1.0> [--label L]
  clear-progress
  log [--level info|warn|err] [--source NAME] "message"
                                    Push a line to the sidebar log of the
                                    active (or --surface) pane.
                                    Example:
                                      ht log --level warn --source build \
                                        "tsc reported 3 errors"

Notifications:
  notify [--title T] [--body B]         Create a notification
  list-notifications                    List notifications
  clear-notifications                   Clear all notifications

Live Metadata (reads from polled surface state):
  metadata [--surface S]                Summary: pid, fg, cwd, counts
  wait-ready [--surface S] [--timeout-ms N]
                                        Block until surface metadata is
                                        observable (or timeout, default 2000 ms).
                                        Use to synchronize automation that races
                                        the post-spawn metadata poll.
  cwd [--surface S]                     Print cwd of foreground process
  ps [--surface S]                      Process tree rooted at the shell
  ports [--surface S]                   Listening TCP ports for tree pids
  git [--surface S]                     Git branch, ahead/behind, dirty counts
  open [PORT] [--surface S]             Open http://localhost:PORT in browser
                                        (resolves from surface metadata if no PORT)
  kill PORT [--signal SIG] [--surface S] Send SIG (default SIGTERM) to the pid
                                        bound to PORT

${BROWSER_HELP}

Sideband panels:
  panels [--surface S]                  List active sideband panels on a surface
  list-panels                           Alias of panels

Script runner:
  run-script --cwd DIR --command CMD [--workspace W] [--script-key K]
                                        Spawn a surface running CMD in DIR
                                        (same pipeline the sidebar uses for
                                        package.json script launches)

Agent panes:
  agent new                             Create a new agent surface
  agent split [horizontal|vertical]     Split the focused pane with an agent
  agent list                            List live agents
  agent count                           Number of live agents
  agent close [id]                      Close an agent by agent/surface id

Telegram:
  telegram status                       Show bot service state (disabled / starting /
                                        polling / error: <reason>)
  telegram restart                      Tear down + restart the long-poll service.
                                        Use to clear stuck backoff after a transient
                                        API outage or right after rotating the bot
                                        token in Settings.
  telegram chats                        List known chats with last-seen times
  telegram read [--chat ID] [--limit N] Print recent messages for a chat
                                        (default limit 20). When --chat /
                                        $HT_TELEGRAM_CHAT are absent, defaults to
                                        the most recently active chat.
  telegram send [--chat ID] [TEXT…]     Send TEXT (joined with spaces) to a chat.
                                        When TEXT is omitted, body is read from
                                        piped stdin. When --chat / $HT_TELEGRAM_CHAT
                                        are absent, defaults to the most recently
                                        active chat (e.g. echo "ok" | ht telegram send).

System:
  shutdown                              Graceful exit (flushes settings,
                                        layout, cookies, history)
  doctor                                Print socket path, reachability,
                                        log file location, app + bun
                                        versions. Run this first when
                                        debugging.
  logs [--tail]                         Print today's log file path. With
                                        --tail, stream new lines (tail -F).

Startup audits:
  audit [list]                          List the cached audit results
                                        (the app reruns once at boot).
  audit run                             Re-run every registered audit.
  audit fix <id>                        Apply the audit's one-step fix
                                        and re-verify.

Subsystem health:
  health                                Aggregated state of every wired
                                        subsystem (pty, socket, web mirror,
                                        telegram, audits). Exits with the
                                        same code regardless of state — for
                                        scripting, parse the JSON output via
                                        --json or rely on the prefix marker
                                        (✓ OK vs ✗ DEGRADED).

Agent plan (Plan #09):
  plan list                             Print every active plan in the
                                        bun-side PlanStore.
  plan set --workspace W [--agent A]    Replace the plan. --json carries the
       --json '<steps>'                 array of {id,title,state}.
  plan update <stepId> [--workspace W]  Patch one step. --state =
       --state done|active|waiting|err  done|active|waiting|err. --title
       [--title T]                      replaces the step title.
  plan complete --workspace W           Mark every step as done.
  plan clear --workspace W              Drop the plan entirely.

Auto-continue (Plan #09):
  autocontinue status                   Print engine config + paused list.
  autocontinue audit [--limit N]        Print last N decisions (default 20,
                                        cap 50).
  autocontinue set --engine X           Persist a partial settings update.
       [--dry-run BOOL] [--cooldown MS] X = off|heuristic|model|hybrid.
       [--max N] [--model NAME]
       [--api-key-env VAR]
  autocontinue fire <surface>           Manual dispatch on a surface — runs
                                        the same lookup pipeline used for
                                        turn-end notifications.
  autocontinue pause <surface>          Pause auto-continue for a surface
                                        until a sibling 'resume' or until
                                        the user types into that terminal.
  autocontinue resume <surface>         Clear the pause and reset the
                                        runaway counter.

Ask the user (Plan #10):
  ask <kind> --title T [--body B]       Block until the user answers via a
       [--choices id:label,...]         sibling 'ht ask answer'. Kinds:
       [--default V] [--timeout MS]     yesno | choice | text |
       [--unsafe true]                  confirm-command. Prints the chosen
                                        value on stdout; exits non-zero on
                                        cancel/timeout.
  ask pending [--surface S]             List pending questions.
  ask answer <id> <value>               Resolve a pending question.
  ask cancel <id> [--reason ...]        Cancel a pending question.

Aliases:
  capture-pane                          Alias for read-screen (tmux compat)

Environment:
  HT_SOCKET_PATH    Override socket path (default: /tmp/hyperterm.sock)
  HT_SURFACE        Auto-set in τ-mux panes — used as default --surface,
                    and the server resolves the owning workspace from it
  HT_WORKSPACE_ID   Optional override for --workspace (not auto-set)
  HT_TELEGRAM_CHAT  Default chat id for "ht telegram read | send"

Add --json to any command for raw JSON output.`);
}

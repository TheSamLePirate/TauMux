node_modules/
build/
dist/
*.app
*.dmg
*.zst
.DS_Store
__pycache__/
*.pyc
artifacts/
# Web-mirror client build artifacts (produced by scripts/build-web-client.ts)
assets/web-client/
# Bun's incremental-build cache files land at repo root (~60 MB each)
*.bun-build
# Secrets / env overrides — never check these in
.env
.env.*
# Local log spillage (claude session transcripts, debug logs, etc.)
*.log
*.jsonl
# Playwright e2e artifacts — traces, screenshots, videos, reports
/test-results/
/playwright-report/
/playwright/.cache/
# Pixel-diff baseline (scripts/baseline-screenshots.ts). Lives outside
# /test-results/ because Playwright wipes that directory on every run.
/.screenshot-baseline/
# Design-report staging — PNGs + JSONL survive between `test:e2e` and
# `test:native` by living outside /test-results/ (Playwright wipes that).
/.design-artifacts/

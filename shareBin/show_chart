#!/usr/bin/env bun
/**
 * τ-mux — show_chart
 *
 * Render a CSV / TSV column as a line / bar / scatter chart in a
 * full-pane sideband panel. The SVG is re-rendered at the new
 * dimensions every time the host pane resizes, so the plot grows
 * with the terminal instead of being stretched.
 *
 * Usage:
 *   show_chart data.csv                          # default: line, x=0, y=1
 *   show_chart --kind bar --y 1,2,3 data.csv
 *   ps -A o pcpu,rss | show_chart --tsv          # streamed input
 *
 * Flags:
 *   --kind line|bar|scatter      chart kind (default line)
 *   --x N                        x-column index (default 0)
 *   --y N[,N...]                 y-column indices (default "1")
 *   --csv / --tsv                separator override (default auto)
 *   --no-header                  treat row 0 as data, not labels
 *   --title "..."                title rendered above the chart
 */

import {
  CATPPUCCIN,
  fullScreenHtml,
  fullScreenPage,
  type FullScreenSize,
} from "./lib/full-screen";
import { parseCsv } from "./lib/csv";
import { type ChartKind, renderChart } from "./lib/chart";
import { escapeHtml } from "./lib/escape";
import { parseArgs, readInput } from "./lib/cli";

let parsed;
try {
  parsed = parseArgs(process.argv.slice(2), {
    schema: [
      { name: "kind", long: "kind", kind: "string", default: "line" },
      { name: "xCol", long: "x", kind: "number", default: 0 },
      { name: "yCols", long: "y", kind: "string", default: "1" },
      { name: "tsv", long: "tsv", kind: "boolean", default: false },
      { name: "csv", long: "csv", kind: "boolean", default: false },
      { name: "noHeader", long: "no-header", kind: "boolean", default: false },
      { name: "title", long: "title", kind: "string", default: "" },
    ] as const,
  });
} catch (err) {
  console.error(`show_chart: ${(err as Error).message}`);
  process.exit(1);
}

const { positional, flags } = parsed;

if (!["line", "bar", "scatter"].includes(flags.kind)) {
  console.error(
    `show_chart: invalid --kind "${flags.kind}" (use line, bar, or scatter)`,
  );
  process.exit(1);
}

const path = positional[0] ?? "";
const raw = readInput(path, { utility: "show_chart", expecting: "CSV/TSV" });
const sep: "," | "\t" | "auto" = flags.tsv ? "\t" : flags.csv ? "," : "auto";
const rows = parseCsv(raw, { sep });

const yCols = flags.yCols
  .split(",")
  .map((s) => Number(s.trim()))
  .filter((n) => Number.isFinite(n));
if (yCols.length === 0) {
  console.error(
    'show_chart: --y must contain at least one column index (e.g. "1" or "1,2,3")',
  );
  process.exit(1);
}

const titleLabel = path ? escapeHtml(path) : "stdin";
const subtitle = `${rows.length - (flags.noHeader ? 0 : 1)} rows · ${yCols.length} series`;

// Chrome takes a small slice off the top — `fullScreenPage` renders
// a header bar and the body has 16 px of vertical padding. Subtract
// both from the chart's effective drawing area so the SVG fills the
// panel exactly without overflowing into a scrollbar.
const HEADER_H = 41;
const BODY_PAD = 16;

function renderPage(size: FullScreenSize): string {
  const w = Math.max(280, size.width - BODY_PAD * 2);
  const h = Math.max(200, size.height - HEADER_H - BODY_PAD * 2);
  const svg = renderChart(rows, {
    kind: flags.kind as ChartKind,
    xCol: flags.xCol,
    yCols,
    hasHeader: !flags.noHeader,
    width: w,
    height: h,
    title: flags.title || undefined,
  });
  return fullScreenPage({
    tag: { label: flags.kind.toUpperCase(), color: CATPPUCCIN.sky },
    title: titleLabel,
    subtitle,
    body: `<div class="ch-frame">${svg}</div>`,
    extraCss: `
.fs-body { padding: ${BODY_PAD}px; }
.ch-frame { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
.ch-frame svg { display: block; max-width: 100%; max-height: 100%; }
`,
  });
}

fullScreenHtml({ render: renderPage });

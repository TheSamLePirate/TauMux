#!/usr/bin/env bun
/**
 * τ-mux — show_chart
 *
 * Render a CSV / TSV column as a line / bar / scatter chart.
 *
 * Usage:
 *   show_chart data.csv                          # default: line, x=0, y=1
 *   show_chart --kind bar --y 1,2,3 data.csv
 *   ps -A o pcpu,rss | show_chart --tsv          # streamed input
 *   show_chart --x 0 --y 2,3 --kind scatter sales.csv
 *
 * Flags:
 *   --kind line|bar|scatter      chart kind (default line)
 *   --x N                        x-column index (default 0)
 *   --y N[,N...]                 y-column indices (default "1")
 *   --csv / --tsv                separator override (default auto)
 *   --no-header                  treat row 0 as data, not labels
 *   --title "..."                title rendered above the chart
 *   --inline / --x / --y / --width / --height / --no-wait
 */

import { ht } from "./hyperterm";
import { parseCsv } from "./lib/csv";
import { type ChartKind, renderChart } from "./lib/chart";
import { escapeHtml } from "./lib/escape";
import { PANEL_FLAGS, parseArgs, readInput } from "./lib/cli";

if (!ht.available) {
  console.error("show_chart: not running inside τ-mux.");
  process.exit(1);
}

let parsed;
try {
  parsed = parseArgs(process.argv.slice(2), {
    schema: [
      ...PANEL_FLAGS,
      { name: "kind", long: "kind", kind: "string", default: "line" },
      { name: "xCol", long: "x-col", kind: "number", default: 0 },
      { name: "yCols", long: "y", kind: "string", default: "1" },
      { name: "tsv", long: "tsv", kind: "boolean", default: false },
      { name: "csv", long: "csv", kind: "boolean", default: false },
      { name: "noHeader", long: "no-header", kind: "boolean", default: false },
      { name: "title", long: "title", kind: "string", default: "" },
    ] as const,
  });
} catch (err) {
  console.error(`show_chart: ${(err as Error).message}`);
  process.exit(1);
}

const { positional, flags } = parsed;
// Override the default 520 width — charts breathe better wider.
const width = flags.width === 520 ? 760 : flags.width;
const height = flags.height === 480 ? 400 : flags.height;

if (!["line", "bar", "scatter"].includes(flags.kind)) {
  console.error(`show_chart: invalid --kind "${flags.kind}" (use line, bar, or scatter)`);
  process.exit(1);
}

const path = positional[0] ?? "";
const raw = readInput(path, {
  utility: "show_chart",
  expecting: "CSV/TSV",
});

const sep: "," | "\t" | "auto" = flags.tsv ? "\t" : flags.csv ? "," : "auto";
const rows = parseCsv(raw, { sep });

const yCols = flags.yCols
  .split(",")
  .map((s) => Number(s.trim()))
  .filter((n) => Number.isFinite(n));
if (yCols.length === 0) {
  console.error('show_chart: --y must contain at least one column index (e.g., "1" or "1,2,3")');
  process.exit(1);
}

const svg = renderChart(rows, {
  kind: flags.kind as ChartKind,
  xCol: flags.xCol,
  yCols,
  hasHeader: !flags.noHeader,
  width,
  height,
  title: flags.title || undefined,
});

const title = path ? escapeHtml(path) : "stdin";
const html = `<div class="ch-pane">
  <header><span class="ch-tag">${flags.kind.toUpperCase()}</span><span class="ch-source">${title}</span></header>
  <div class="ch-frame">${svg}</div>
</div>
<style>
  body { margin: 0; }
  .ch-pane {
    font-family: ui-monospace, SF Mono, "JetBrains Mono", monospace;
    color: #d6d8dc;
    background: rgba(20, 24, 30, 0.97);
    padding: 10px 14px;
    border-radius: 10px;
    height: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 11px;
  }
  .ch-pane header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding-bottom: 6px;
    letter-spacing: 0.04em;
  }
  .ch-tag { color: #66c0f4; font-weight: 600; }
  .ch-source { color: #9aa0a6; }
  .ch-frame { flex: 1 1 auto; display: flex; align-items: center; justify-content: center; min-height: 0; }
  .ch-frame svg { max-width: 100%; max-height: 100%; }
</style>`;

const panelId = ht.showHtml(html, {
  position: flags.inline ? "inline" : "float",
  x: flags.x,
  y: flags.y,
  width,
  height,
  draggable: true,
  resizable: true,
});

if (!flags.noWait) {
  await ht.waitForClose(panelId).catch(() => {});
}

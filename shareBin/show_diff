#!/usr/bin/env bun
/**
 * τ-mux — show_diff
 *
 * Render a unified diff side-by-side in a sideband panel.
 *
 * Usage:
 *   show_diff patch.diff             # render a file
 *   git diff | show_diff             # read piped stdin
 *   show_diff --inline patch.diff
 *
 * Flags:
 *   --inline / --x / --y / --width / --no-wait — same shape as show_md.
 */

import { readFileSync } from "node:fs";
import { ht } from "./hyperterm";
import { renderUnifiedDiff } from "./lib/diff-render";
import { escapeHtml } from "./lib/escape";

if (!ht.available) {
  console.error("show_diff: not running inside τ-mux.");
  process.exit(1);
}

const argv = process.argv.slice(2);
const flags = { inline: false, noWait: false };
let x = 80;
let y = 80;
let width = 820;
let path = "";
for (let i = 0; i < argv.length; i++) {
  const a = argv[i]!;
  if (a === "--inline") flags.inline = true;
  else if (a === "--no-wait") flags.noWait = true;
  else if (a === "--x") x = parseInt(argv[++i] ?? "80", 10);
  else if (a === "--y") y = parseInt(argv[++i] ?? "80", 10);
  else if (a === "--width") width = parseInt(argv[++i] ?? "820", 10);
  else if (!path) path = a;
}

let source: string;
if (path) {
  try {
    source = readFileSync(path, "utf8");
  } catch (err) {
    console.error(
      `show_diff: cannot read ${path}: ${(err as Error).message}`,
    );
    process.exit(1);
  }
} else if (!process.stdin.isTTY) {
  source = readFileSync(0, "utf8");
} else {
  console.error(
    "show_diff: no input — pass a file path or pipe a unified diff into stdin",
  );
  process.exit(1);
}

const table = renderUnifiedDiff(source);
const title = path ? escapeHtml(path) : "stdin";
const html = `<div class="diff-pane">
  <header><span class="diff-source">${title}</span></header>
  <div class="diff-scroll">${table}</div>
</div>
<style>
  body { margin: 0; }
  .diff-pane {
    font-family: ui-monospace, SF Mono, "JetBrains Mono", monospace;
    font-size: 11.5px;
    color: #d6d8dc;
    background: rgba(20, 24, 30, 0.97);
    padding: 12px 0 0;
    border-radius: 10px;
    height: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }
  .diff-pane header {
    padding: 0 14px 8px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: #66c0f4;
  }
  .diff-scroll { overflow: auto; flex: 1 1 auto; min-height: 0; }
  table.diff {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  table.diff td {
    width: 50%;
    padding: 1px 8px;
    vertical-align: top;
    line-height: 1.5;
    border-bottom: 1px solid rgba(255,255,255,0.02);
    overflow-wrap: anywhere;
  }
  table.diff td code {
    font-family: inherit;
    white-space: pre-wrap;
    word-break: break-word;
  }
  td.diff-add {
    background: rgba(76, 175, 80, 0.14);
    color: #a6e3a1;
  }
  td.diff-del {
    background: rgba(244, 67, 54, 0.14);
    color: #f38ba8;
  }
  td.diff-ctx {
    color: #b3b6bb;
  }
  tr.diff-sep td {
    background: rgba(102, 192, 244, 0.08);
    color: #66c0f4;
    padding: 4px 14px;
    font-weight: 600;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
</style>`;

const panelId = ht.showHtml(html, {
  position: flags.inline ? "inline" : "float",
  x,
  y,
  width,
  height: 520,
  draggable: true,
  resizable: true,
});

if (!flags.noWait) {
  await ht.waitForClose(panelId).catch(() => {});
}

#!/usr/bin/env bun
/**
 * τ-mux — show_diff
 *
 * Render a unified diff side-by-side in a full-pane sideband
 * panel. The panel is pinned to the host pane, follows terminal
 * resizes, and exits when the user closes it.
 *
 * Usage:
 *   show_diff patch.diff             # render a file
 *   git diff | show_diff             # read piped stdin
 */

import { fullScreenHtml, fullScreenPage, CATPPUCCIN } from "./lib/full-screen";
import { renderUnifiedDiff } from "./lib/diff-render";
import { escapeHtml } from "./lib/escape";
import { readInput } from "./lib/cli";

const argv = process.argv.slice(2);
const path = argv.find((a) => !a.startsWith("--")) ?? "";

const source = readInput(path, {
  utility: "show_diff",
  expecting: "a unified diff",
});

const table = renderUnifiedDiff(source);
const titleLabel = path ? escapeHtml(path) : "stdin";

// Counted once at startup — informational only, no need to recount
// on resize. The diff itself doesn't change while the panel is up.
const stats = countStats(source);

fullScreenHtml({
  render: () =>
    fullScreenPage({
      tag: { label: "DIFF", color: CATPPUCCIN.peach },
      title: titleLabel,
      subtitle: `<span style="color:${CATPPUCCIN.green}">+${stats.added}</span>  <span style="color:${CATPPUCCIN.red}">−${stats.deleted}</span>  ${stats.hunks} hunk${stats.hunks === 1 ? "" : "s"}`,
      body: table,
      extraCss: `
.fs-body { padding: 0; }
table.diff { width: 100%; border-collapse: collapse; table-layout: fixed; }
table.diff td {
  width: 50%;
  padding: 1px 12px;
  vertical-align: top;
  line-height: 1.55;
  border-bottom: 1px solid rgba(255,255,255,0.025);
  overflow-wrap: anywhere;
}
table.diff td code {
  font-family: inherit;
  white-space: pre-wrap;
  word-break: break-word;
}
td.diff-add { background: rgba(166, 227, 161, 0.12); color: ${CATPPUCCIN.green}; }
td.diff-del { background: rgba(243, 139, 168, 0.12); color: ${CATPPUCCIN.red}; }
td.diff-ctx { color: ${CATPPUCCIN.subtext1}; }
tr.diff-sep td {
  background: ${CATPPUCCIN.surface0};
  color: ${CATPPUCCIN.blue};
  padding: 6px 14px;
  font-weight: 600;
  border-bottom: 1px solid ${CATPPUCCIN.surface1};
}
`,
    }),
});

function countStats(input: string): {
  added: number;
  deleted: number;
  hunks: number;
} {
  let added = 0;
  let deleted = 0;
  let hunks = 0;
  for (const line of input.split("\n")) {
    if (line.startsWith("@@")) hunks++;
    else if (line.startsWith("+") && !line.startsWith("+++")) added++;
    else if (line.startsWith("-") && !line.startsWith("---")) deleted++;
  }
  return { added, deleted, hunks };
}

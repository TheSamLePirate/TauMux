#!/usr/bin/env bun
/**
 * τ-mux — show_sysmon
 *
 * Full-pane system monitor — CPU arc gauge, per-core load bars,
 * RAM/disk meters, top processes, network rates, load average, a
 * scrolling CPU sparkline, and uptime. Updates every second; the
 * layout reflows as the host pane resizes; closes on the panel's
 * X button or any of SIGINT/SIGTERM/SIGHUP.
 *
 * Usage:
 *   show_sysmon
 *   show_sysmon --interval 500    # ms between samples (default 1000)
 */

import { cpus, totalmem, freemem, loadavg, uptime as osUptime } from "node:os";
import { readFileSync } from "node:fs";
import {
  CATPPUCCIN,
  fullScreenHtml,
  type FullScreenSize,
} from "./lib/full-screen";
import { parseArgs } from "./lib/cli";
import { escapeHtml } from "./lib/escape";

let parsed;
try {
  parsed = parseArgs(process.argv.slice(2), {
    schema: [
      { name: "interval", long: "interval", kind: "number", default: 1000 },
    ] as const,
  });
} catch (err) {
  console.error(`show_sysmon: ${(err as Error).message}`);
  process.exit(1);
}

const UPDATE_INTERVAL = Math.max(250, parsed.flags.interval);
const SUBPROCESS_TIMEOUT_MS = 3000;
const SPARKLINE_MAX = 120;
const NET_IFACE_RE = /^(en|wlan|eth|wl|docker|lo|enp|eno|ens|br-|veth)/;

// ── Data collection ──

interface SystemData {
  cpuPct: number;
  corePcts: number[];
  ramUsed: number;
  ramTotal: number;
  diskUsed: number;
  diskTotal: number;
  load: [number, number, number];
  topProcs: { cpu: number; name: string; pid: number }[];
  netRxRate: number;
  netTxRate: number;
  uptimeStr: string;
}

const prevIdleTotals: number[] = [];
const prevTotalTotals: number[] = [];
const cpuHistory: number[] = [];
let prevNetRx = 0;
let prevNetTx = 0;
let netRxRate = 0;
let netTxRate = 0;
let netInitialized = false;

function getCpuUsage(): { total: number; perCore: number[] } {
  const cores = cpus();
  const corePcts: number[] = [];
  let totalIdle = 0;
  let totalAll = 0;
  for (let i = 0; i < cores.length; i++) {
    const t = cores[i]!.times;
    const idle = t.idle;
    const total = t.user + t.nice + t.sys + t.idle + t.irq;
    const prevIdle = prevIdleTotals[i] ?? idle;
    const prevTotal = prevTotalTotals[i] ?? total;
    const dIdle = idle - prevIdle;
    const dTotal = total - prevTotal;
    prevIdleTotals[i] = idle;
    prevTotalTotals[i] = total;
    totalIdle += dIdle;
    totalAll += dTotal;
    corePcts.push(dTotal === 0 ? 0 : Math.round((1 - dIdle / dTotal) * 100));
  }
  return {
    total: totalAll === 0 ? 0 : Math.round((1 - totalIdle / totalAll) * 100),
    perCore: corePcts,
  };
}

async function spawnText(cmd: string[]): Promise<string> {
  try {
    const proc = Bun.spawn(cmd, {
      stdout: "pipe",
      stderr: "pipe",
      timeout: SUBPROCESS_TIMEOUT_MS,
      env: { ...process.env, LC_ALL: "C", LANG: "C" },
    });
    const killTimer = setTimeout(() => {
      try {
        proc.kill();
      } catch {
        /* ignore */
      }
    }, SUBPROCESS_TIMEOUT_MS + 250);
    const text = await new Response(proc.stdout).text();
    await proc.exited;
    clearTimeout(killTimer);
    return text;
  } catch {
    return "";
  }
}

async function getDiskUsage(): Promise<{ used: number; total: number }> {
  const text = await spawnText(["df", "-k", "/"]);
  const lines = text.trim().split("\n");
  if (lines.length < 2) return { used: 0, total: 1 };
  const parts = lines[1]!.split(/\s+/);
  const totalKb = parseInt(parts[1] ?? "0") || 0;
  const usedKb = parseInt(parts[2] ?? "0") || 0;
  return { used: usedKb * 1024, total: totalKb * 1024 };
}

async function getTopProcesses(): Promise<
  { cpu: number; name: string; pid: number }[]
> {
  const text = await spawnText(["ps", "-eo", "pid,pcpu,comm", "-r"]);
  const lines = text.trim().split("\n").slice(1);
  const out: { cpu: number; name: string; pid: number }[] = [];
  for (const line of lines) {
    if (out.length >= 12) break;
    const m = line.trim().match(/^(\d+)\s+([\d.]+)\s+(.+)$/);
    if (!m) continue;
    const pid = parseInt(m[1]!, 10);
    const cpu = parseFloat(m[2]!);
    const name = (m[3] ?? "").split("/").pop() ?? "";
    if (cpu > 0) out.push({ pid, cpu, name: name.slice(0, 28) });
  }
  return out;
}

function parseProcNetDev(text: string): { rx: number; tx: number } | null {
  const lines = text.split("\n");
  if (lines.length < 3) return null;
  let rx = 0;
  let tx = 0;
  let matched = false;
  for (let i = 2; i < lines.length; i++) {
    const line = lines[i]!.trim();
    if (!line) continue;
    const colonIdx = line.indexOf(":");
    if (colonIdx < 0) continue;
    const iface = line.slice(0, colonIdx).trim();
    if (!NET_IFACE_RE.test(iface)) continue;
    const parts = line.slice(colonIdx + 1).trim().split(/\s+/);
    if (parts.length < 16) continue;
    const ibytes = parseInt(parts[0] ?? "");
    const obytes = parseInt(parts[8] ?? "");
    if (Number.isFinite(ibytes) && Number.isFinite(obytes)) {
      rx += ibytes;
      tx += obytes;
      matched = true;
    }
  }
  return matched ? { rx, tx } : null;
}

async function getNetworkStatsViaNetstat(): Promise<
  { rx: number; tx: number } | null
> {
  const text = await spawnText(["/usr/sbin/netstat", "-ib"]);
  if (!text) return null;
  const lines = text.trim().split("\n");
  let totalRx = 0;
  let totalTx = 0;
  let matched = false;
  for (let i = 1; i < lines.length; i++) {
    const parts = lines[i]!.split(/\s+/);
    if (parts[0] && NET_IFACE_RE.test(parts[0]) && parts.length >= 10) {
      const ibytes = parseInt(parts[6] ?? "");
      const obytes = parseInt(parts[9] ?? "");
      if (Number.isFinite(ibytes) && Number.isFinite(obytes)) {
        totalRx += ibytes;
        totalTx += obytes;
        matched = true;
      }
    }
  }
  return matched ? { rx: totalRx, tx: totalTx } : null;
}

async function refreshNetwork(): Promise<void> {
  let stats = await getNetworkStatsViaNetstat();
  if (!stats) {
    try {
      stats = parseProcNetDev(readFileSync("/proc/net/dev", "utf8"));
    } catch {
      stats = null;
    }
  }
  if (!stats) return;
  if (netInitialized) {
    netRxRate = Math.max(0, stats.rx - prevNetRx);
    netTxRate = Math.max(0, stats.tx - prevNetTx);
  }
  prevNetRx = stats.rx;
  prevNetTx = stats.tx;
  netInitialized = true;
}

function formatBytes(bytes: number): string {
  if (bytes >= 1e12) return (bytes / 1e12).toFixed(1) + " TB";
  if (bytes >= 1e9) return (bytes / 1e9).toFixed(1) + " GB";
  if (bytes >= 1e6) return (bytes / 1e6).toFixed(1) + " MB";
  if (bytes >= 1e3) return (bytes / 1e3).toFixed(1) + " KB";
  return bytes + " B";
}

function formatRate(bytesPerSec: number): string {
  if (bytesPerSec >= 1e6) return (bytesPerSec / 1e6).toFixed(1) + " MB/s";
  if (bytesPerSec >= 1e3) return (bytesPerSec / 1e3).toFixed(1) + " KB/s";
  return bytesPerSec + " B/s";
}

function formatUptime(seconds: number): string {
  const days = Math.floor(seconds / 86400);
  const hours = Math.floor((seconds % 86400) / 3600);
  const mins = Math.floor((seconds % 3600) / 60);
  if (days > 0) return `${days}d ${hours}h ${mins}m`;
  if (hours > 0) return `${hours}h ${mins}m`;
  return `${mins}m`;
}

function usageColor(pct: number): string {
  if (pct >= 85) return CATPPUCCIN.red;
  if (pct >= 60) return CATPPUCCIN.yellow;
  return CATPPUCCIN.green;
}

// ── SVG helpers ──

function arcPath(cx: number, cy: number, r: number, pct: number): string {
  const startAngle = -225;
  const totalSweep = 270;
  const endAngle =
    startAngle + (totalSweep * Math.min(100, Math.max(0, pct))) / 100;
  const toRad = (deg: number) => (deg * Math.PI) / 180;
  const x1 = cx + r * Math.cos(toRad(startAngle));
  const y1 = cy + r * Math.sin(toRad(startAngle));
  const x2 = cx + r * Math.cos(toRad(endAngle));
  const y2 = cy + r * Math.sin(toRad(endAngle));
  const sweep = (totalSweep * pct) / 100;
  const largeArc = sweep > 180 ? 1 : 0;
  return `M ${x1.toFixed(1)} ${y1.toFixed(1)} A ${r} ${r} 0 ${largeArc} 1 ${x2.toFixed(1)} ${y2.toFixed(1)}`;
}

function arcTrackPath(cx: number, cy: number, r: number): string {
  return arcPath(cx, cy, r, 99.9);
}

function sparklinePath(
  data: number[],
  w: number,
  h: number,
): { line: string; fill: string; color: string } {
  if (data.length < 2) return { line: "", fill: "", color: CATPPUCCIN.green };
  const stride = w / (SPARKLINE_MAX - 1);
  const pts = data.map((v, i) => {
    const px = i * stride;
    const py = h - (v / 100) * h;
    return `${px.toFixed(1)},${py.toFixed(1)}`;
  });
  const last = data[data.length - 1] ?? 0;
  const color = usageColor(last);
  const fillPts = `0,${h.toFixed(1)} ${pts.join(" ")} ${((data.length - 1) * stride).toFixed(1)},${h.toFixed(1)}`;
  return { line: pts.join(" "), fill: fillPts, color };
}

// ── Layout ──

function computeColumnLayout(width: number): "single" | "double" | "triple" {
  if (width >= 1280) return "triple";
  if (width >= 820) return "double";
  return "single";
}

function renderArcGauge(pct: number, label: string): string {
  const cx = 90;
  const cy = 88;
  const r = 64;
  const color = usageColor(pct);
  return `<svg viewBox="0 0 180 180" preserveAspectRatio="xMidYMid meet" class="sm-gauge">
  <path d="${arcTrackPath(cx, cy, r)}" fill="none" stroke="${CATPPUCCIN.surface0}" stroke-width="10" stroke-linecap="round"/>
  <path d="${arcPath(cx, cy, r, pct)}" fill="none" stroke="${color}" stroke-width="10" stroke-linecap="round"/>
  <text x="${cx}" y="${cy + 6}" text-anchor="middle" fill="${color}" font-size="36" font-weight="700" font-family="ui-monospace,monospace">${pct}%</text>
  <text x="${cx}" y="${cy + 28}" text-anchor="middle" fill="${CATPPUCCIN.overlay0}" font-size="11" letter-spacing="2" font-family="ui-monospace,monospace">${label}</text>
</svg>`;
}

function renderMeter(label: string, used: number, total: number, valueText: string): string {
  const pct = total > 0 ? (used / total) * 100 : 0;
  const color = usageColor(pct);
  return `<div class="sm-meter">
  <div class="sm-meter-row"><span class="sm-meter-label">${label}</span><span class="sm-meter-value">${valueText}</span></div>
  <div class="sm-meter-track"><div class="sm-meter-fill" style="width:${Math.min(100, pct).toFixed(1)}%;background:${color}"></div></div>
</div>`;
}

function renderCoreBars(corePcts: number[]): string {
  const cells = corePcts.map((pct, i) => {
    const color = usageColor(pct);
    return `<div class="sm-core">
      <span class="sm-core-idx">${i}</span>
      <div class="sm-core-track"><div class="sm-core-fill" style="width:${Math.min(100, pct)}%;background:${color}"></div></div>
      <span class="sm-core-pct" style="color:${color}">${pct}%</span>
    </div>`;
  });
  return `<div class="sm-cores">${cells.join("")}</div>`;
}

function renderTopProcs(procs: SystemData["topProcs"]): string {
  if (procs.length === 0) return `<div class="sm-empty">no data</div>`;
  const max = Math.max(1, ...procs.map((p) => p.cpu));
  const rows = procs.map((p) => {
    const pct = (p.cpu / max) * 100;
    return `<div class="sm-proc">
      <span class="sm-proc-cpu">${p.cpu.toFixed(1)}%</span>
      <span class="sm-proc-name" title="${escapeHtml(p.name)}">${escapeHtml(p.name)}</span>
      <span class="sm-proc-pid">${p.pid}</span>
      <div class="sm-proc-bar"><div style="width:${pct.toFixed(1)}%"></div></div>
    </div>`;
  });
  return `<div class="sm-procs">${rows.join("")}</div>`;
}

function renderSparkline(data: number[], width: number, height: number): string {
  const sp = sparklinePath(data, width, height);
  if (!sp.line) return `<div class="sm-spark-empty">collecting…</div>`;
  return `<svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" class="sm-spark">
    <polygon points="${sp.fill}" fill="${sp.color}" opacity="0.18"/>
    <polyline points="${sp.line}" fill="none" stroke="${sp.color}" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
  </svg>`;
}

function renderPage(data: SystemData, size: FullScreenSize): string {
  const cols = computeColumnLayout(size.width);
  const ramText = `${formatBytes(data.ramUsed)} / ${formatBytes(data.ramTotal)}`;
  const diskText = `${formatBytes(data.diskUsed)} / ${formatBytes(data.diskTotal)}`;
  const sparkColor = usageColor(data.cpuPct);
  const cores = renderCoreBars(data.corePcts);
  const procs = renderTopProcs(data.topProcs);
  const gauge = renderArcGauge(data.cpuPct, "CPU");
  const sparkW = 600;
  const sparkH = 100;
  const sparkline = renderSparkline(cpuHistory, sparkW, sparkH);

  return `<div class="sm-shell">
  <header class="sm-header">
    <span class="sm-tag">SYSMON</span>
    <span class="sm-title">${process.platform} · ${cpus().length} cores</span>
    <span class="sm-spacer"></span>
    <span class="sm-load">load <b>${data.load[0].toFixed(2)}</b> · <b>${data.load[1].toFixed(2)}</b> · <b>${data.load[2].toFixed(2)}</b></span>
    <span class="sm-pulse" style="background:${sparkColor}"></span>
    <span class="sm-uptime">up ${escapeHtml(data.uptimeStr)}</span>
  </header>
  <div class="sm-grid sm-grid-${cols}">
    <section class="sm-card sm-cpu">
      <h2>CPU</h2>
      <div class="sm-cpu-row">
        <div class="sm-gauge-wrap">${gauge}</div>
        <div class="sm-cores-wrap">${cores}</div>
      </div>
    </section>
    <section class="sm-card sm-mem">
      <h2>Memory & Disk</h2>
      ${renderMeter("RAM", data.ramUsed, data.ramTotal, ramText)}
      ${renderMeter("DISK", data.diskUsed, data.diskTotal, diskText)}
      <div class="sm-net">
        <div class="sm-net-cell"><span class="sm-net-label">↓ NET RX</span><span class="sm-net-rate" style="color:${CATPPUCCIN.teal}">${formatRate(data.netRxRate)}</span></div>
        <div class="sm-net-cell"><span class="sm-net-label">↑ NET TX</span><span class="sm-net-rate" style="color:${CATPPUCCIN.peach}">${formatRate(data.netTxRate)}</span></div>
      </div>
    </section>
    <section class="sm-card sm-procs-card">
      <h2>Top Processes</h2>
      ${procs}
    </section>
    <section class="sm-card sm-spark-card">
      <h2>CPU History (last ${SPARKLINE_MAX}s)</h2>
      <div class="sm-spark-wrap">${sparkline}</div>
    </section>
  </div>
</div>
<style>

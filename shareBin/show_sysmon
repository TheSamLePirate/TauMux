}

// ── State + lifecycle ──

let lastData: SystemData | null = null;

const panel = fullScreenHtml({
  render: (size) => {
    const data = lastData ?? emptyData();
    return renderPage(data, size);
  },
  onExit: () => {
    if (sampleTimer) clearInterval(sampleTimer);
  },
});

// Prime CPU deltas with an initial sample so the first reading is
// based on at least one prior tick instead of the absolute totals.
getCpuUsage();

await sample();
panel.rerender();

const sampleTimer = setInterval(async () => {
  await sample();
  panel.rerender();
}, UPDATE_INTERVAL);

async function sample(): Promise<void> {
  const cpu = getCpuUsage();
  cpuHistory.push(cpu.total);
  if (cpuHistory.length > SPARKLINE_MAX) cpuHistory.shift();

  const ramTotal = totalmem();
  const ramFree = freemem();
  const ramUsed = ramTotal - ramFree;

  const [disk, procs] = await Promise.all([
    getDiskUsage(),
    getTopProcesses(),
  ]);
  await refreshNetwork();

  lastData = {
    cpuPct: cpu.total,
    corePcts: cpu.perCore,
    ramUsed,
    ramTotal,
    diskUsed: disk.used,
    diskTotal: disk.total,
    load: loadavg() as [number, number, number],
    topProcs: procs,
    netRxRate,
    netTxRate,
    uptimeStr: formatUptime(osUptime()),
  };
}

function emptyData(): SystemData {
  return {
    cpuPct: 0,
    corePcts: cpus().map(() => 0),
    ramUsed: 0,
    ramTotal: 1,
    diskUsed: 0,
    diskTotal: 1,

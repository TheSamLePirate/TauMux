#!/usr/bin/env bun
/**
 * τ-mux — show_html
 *
 * Display a chunk of HTML in a sideband panel. The thinnest of
 * thin wrappers — reads the input, calls `ht.showHtml(...)`, and
 * waits for close. Useful for dropping any pre-rendered HTML
 * fragment a script generates without re-implementing the panel
 * scaffolding.
 *
 * Usage:
 *   show_html page.html                        # render a file
 *   echo "<h1>hi</h1>" | show_html             # piped stdin
 *   bun render.ts | show_html --inline         # cursor-anchored
 *
 * Flags:
 *   --inline                  position panel inline at the cursor
 *   --x N --y N               explicit position (float panels)
 *   --width N --height N      explicit dimensions (defaults
 *                              520 × 360 for floats; ignored for
 *                              inline panels which size to content)
 *   --no-wait                 exit after creating the panel
 *
 * Note: HTML from fd4 is rendered without sandbox per
 * `doc/system-canvas-panels.md` — the contract is "fd4 content is
 * trusted because the user spawned the producer". Don't pipe
 * untrusted HTML through this without sanitising first.
 */

import { readFileSync } from "node:fs";
import { ht } from "./hyperterm";

if (!ht.available) {
  console.error("show_html: not running inside τ-mux.");
  process.exit(1);
}

const argv = process.argv.slice(2);
const flags = { inline: false, noWait: false };
let x = 100;
let y = 100;
let width = 520;
let height = 360;
let path = "";
for (let i = 0; i < argv.length; i++) {
  const a = argv[i]!;
  if (a === "--inline") flags.inline = true;
  else if (a === "--no-wait") flags.noWait = true;
  else if (a === "--x") x = parseInt(argv[++i] ?? "100", 10);
  else if (a === "--y") y = parseInt(argv[++i] ?? "100", 10);
  else if (a === "--width") width = parseInt(argv[++i] ?? "520", 10);
  else if (a === "--height") height = parseInt(argv[++i] ?? "360", 10);
  else if (!path) path = a;
}

let html: string;
if (path) {
  try {
    html = readFileSync(path, "utf8");
  } catch (err) {
    console.error(`show_html: cannot read ${path}: ${(err as Error).message}`);
    process.exit(1);
  }
} else if (!process.stdin.isTTY) {
  html = readFileSync(0, "utf8");
} else {
  console.error(
    "show_html: no input — pass a file path or pipe HTML into stdin",
  );
  process.exit(1);
}

const panelId = ht.showHtml(html, {
  position: flags.inline ? "inline" : "float",
  x,
  y,
  width,
  height,
  draggable: true,
  resizable: true,
});

if (!flags.noWait) {
  await ht.waitForClose(panelId).catch(() => {});
}

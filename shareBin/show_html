#!/usr/bin/env bun
/**
 * τ-mux — show_html
 *
 * Display a chunk of HTML in a full-pane sideband panel. The
 * panel is pinned to the host pane, follows terminal resizes, and
 * exits the moment the user closes it.
 *
 * Usage:
 *   show_html page.html                   # render a file
 *   echo "<h1>hi</h1>" | show_html        # piped stdin
 *   bun render.ts | show_html             # output of any tool
 *
 * Note: HTML from fd4 is rendered without sandboxing per
 * `doc/system-canvas-panels.md` — fd4 content is trusted because
 * the user spawned the producer. Don't pipe untrusted HTML through
 * this without sanitising first.
 */

import {
  BASE_CSS,
  CATPPUCCIN,
  fullScreenHtml,
  type FullScreenSize,
} from "./lib/full-screen";
import { PANEL_FLAGS, parseArgs, readInput } from "./lib/cli";
import { escapeHtml } from "./lib/escape";

let parsed;
try {
  parsed = parseArgs(process.argv.slice(2), {
    schema: [...PANEL_FLAGS] as const,
  });
} catch (err) {
  console.error(`show_html: ${(err as Error).message}`);
  process.exit(1);
}

const { positional } = parsed;
const path = positional[0] ?? "";
const html = readInput(path, { utility: "show_html", expecting: "HTML" });
const titleLabel = path ? escapeHtml(path) : "stdin";

// Wrap the user-supplied markup in our standard chrome so the
// panel still gets the dark background, scrollbars, and a header
// bar even when the input HTML doesn't ship its own. The user's
// markup goes inside an iframe-equivalent scrolling body.
function renderPage(_size: FullScreenSize): string {
  return `<div class="sh-shell">
  <header class="sh-header"><span class="sh-tag">HTML</span><span class="sh-title">${titleLabel}</span></header>
  <div class="sh-body">${html}</div>
</div>
<style>
${BASE_CSS}
.sh-shell { display: flex; flex-direction: column; width: 100%; height: 100%; }
.sh-header {
  flex: 0 0 auto;
  display: flex;
  gap: 14px;
  align-items: center;
  padding: 10px 18px;
  border-bottom: 1px solid ${CATPPUCCIN.surface0};
  background: ${CATPPUCCIN.mantle};
  font-size: 11.5px;
  letter-spacing: 0.04em;
}
.sh-tag { color: ${CATPPUCCIN.blue}; font-weight: 700; text-transform: uppercase; }
.sh-title { color: ${CATPPUCCIN.text}; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sh-body { flex: 1 1 auto; min-height: 0; overflow: auto; }
</style>`;
}

fullScreenHtml({ render: renderPage });

#!/usr/bin/env bun
/**
 * τ-mux — show_yaml
 *
 * Render YAML as a collapsible tree in a sideband panel by parsing
 * to a JS value and reusing the JSON tree renderer. The bundled
 * parser is a minimal subset (mappings, sequences, scalars) — for
 * complex YAML (anchors, tags, flow style) pipe through `yq -o
 * json | show_json` instead.
 *
 * Usage:
 *   show_yaml config.yaml                    # render a file
 *   curl ... | show_yaml                     # read piped stdin
 *   show_yaml --depth 4 config.yaml          # default-expanded depth
 *
 * Flags identical to show_json (--depth / --inline / --x / --y /
 * --width / --no-wait).
 */

import { readFileSync } from "node:fs";
import { ht } from "./hyperterm";
import { parseYaml } from "./lib/yaml";
import { renderJsonTree } from "./lib/json-tree";
import { escapeHtml } from "./lib/escape";

if (!ht.available) {
  console.error("show_yaml: not running inside τ-mux.");
  process.exit(1);
}

const argv = process.argv.slice(2);
const flags = { inline: false, noWait: false };
let depth = 2;
let x = 100;
let y = 100;
let width = 520;
let path = "";
for (let i = 0; i < argv.length; i++) {
  const a = argv[i]!;
  if (a === "--inline") flags.inline = true;
  else if (a === "--no-wait") flags.noWait = true;
  else if (a === "--depth") depth = parseInt(argv[++i] ?? "2", 10);
  else if (a === "--x") x = parseInt(argv[++i] ?? "100", 10);
  else if (a === "--y") y = parseInt(argv[++i] ?? "100", 10);
  else if (a === "--width") width = parseInt(argv[++i] ?? "520", 10);
  else if (!path) path = a;
}

let raw: string;
if (path) {
  try {
    raw = readFileSync(path, "utf8");
  } catch (err) {
    console.error(`show_yaml: cannot read ${path}: ${(err as Error).message}`);
    process.exit(1);
  }
} else if (!process.stdin.isTTY) {
  raw = readFileSync(0, "utf8");
} else {
  console.error(
    "show_yaml: no input — pass a file path or pipe YAML into stdin",
  );
  process.exit(1);
}

let value: unknown;
try {
  value = parseYaml(raw);
} catch (err) {
  console.error(
    `show_yaml: parse failed — ${(err as Error).message}\n` +
      "  Try: yq -o json | show_json   for complex YAML.",
  );
  process.exit(1);
}

const tree = renderJsonTree(value, { openDepth: depth });
const title = path ? escapeHtml(path) : "stdin";
const html = `<div class="yt-pane">
  <header><span class="yt-source">${title}</span><span class="yt-tag">YAML</span></header>
  <div class="yt-scroll">${tree}</div>
</div>
<style>
  body { margin: 0; }
  .yt-pane {
    font-family: ui-monospace, SF Mono, "JetBrains Mono", monospace;
    font-size: 12px;
    color: #d6d8dc;
    background: rgba(20, 24, 30, 0.96);
    padding: 12px 14px;
    border-radius: 10px;
    height: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }
  .yt-pane header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding-bottom: 6px;
    margin-bottom: 8px;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: #66c0f4;
  }
  .yt-tag {
    color: #f9e2af;
    font-weight: 600;
  }
  .yt-scroll { overflow: auto; flex: 1 1 auto; min-height: 0; }
  /* Reuse the colour-coded JSON tree styles from show_json */
  .jt-leaf { padding: 1px 0; line-height: 1.5; }
  .jt-key { color: #f5c2e7; }
  .jt-val[data-type="string"] { color: #a6e3a1; }
  .jt-val[data-type="number"] { color: #fab387; }
  .jt-val[data-type="boolean"] { color: #cba6f7; }
  .jt-val[data-type="null"] { color: #6c7086; font-style: italic; }
  .jt-val[data-type="unknown"] { color: #f38ba8; }
  details summary {
    cursor: pointer;
    list-style: none;
    padding: 1px 0;
    line-height: 1.5;
  }
  details summary::-webkit-details-marker { display: none; }
  details summary::before {
    content: "▸";
    display: inline-block;
    width: 12px;
    color: #6c7086;
    transition: transform 120ms;
  }
  details[open] summary::before {
    transform: rotate(90deg);
  }
  .jt-bracket { color: #6c7086; }
  details > .jt-children {
    padding-left: 16px;
    border-left: 1px solid rgba(255,255,255,0.04);
    margin-left: 5px;
  }
</style>`;

const panelId = ht.showHtml(html, {
  position: flags.inline ? "inline" : "float",
  x,
  y,
  width,
  height: 480,
  draggable: true,
  resizable: true,
});

if (!flags.noWait) {
  await ht.waitForClose(panelId).catch(() => {});
}

#!/usr/bin/env bun
/**
 * τ-mux — show_yaml
 *
 * Render YAML as a collapsible tree in a full-pane sideband panel
 * by parsing to a JS value and reusing the JSON tree renderer. The
 * bundled parser is a minimal subset (mappings, sequences,
 * scalars) — for complex YAML (anchors, tags, flow style) pipe
 * through `yq -o json | show_json` instead.
 *
 * Usage:
 *   show_yaml config.yaml
 *   curl ... | show_yaml
 *   show_yaml --depth 4 config.yaml
 *
 * Flags:
 *   --depth N          containers shallower than N start expanded (default 2)
 */

import {
  CATPPUCCIN,
  fullScreenHtml,
  fullScreenPage,
} from "./lib/full-screen";
import { parseYaml } from "./lib/yaml";
import { renderJsonTree } from "./lib/json-tree";
import { escapeHtml } from "./lib/escape";
import { readInput } from "./lib/cli";

const argv = process.argv.slice(2);
const depthIdx = argv.indexOf("--depth");
const depth =
  depthIdx !== -1 && argv[depthIdx + 1] ? parseInt(argv[depthIdx + 1]!, 10) : 2;
const path = argv.find((a) => !a.startsWith("--") && !isDepthValue(a)) ?? "";

function isDepthValue(a: string): boolean {
  return depthIdx !== -1 && argv[depthIdx + 1] === a;
}

const raw = readInput(path, { utility: "show_yaml", expecting: "YAML" });

let value: unknown;
try {
  value = parseYaml(raw);
} catch (err) {
  console.error(
    `show_yaml: parse failed — ${(err as Error).message}\n` +
      "  Try: yq -o json | show_json   for complex YAML.",
  );
  process.exit(1);
}

const tree = renderJsonTree(value, { openDepth: depth });
const titleLabel = path ? escapeHtml(path) : "stdin";

fullScreenHtml({
  render: () =>
    fullScreenPage({
      tag: { label: "YAML", color: CATPPUCCIN.yellow },
      title: titleLabel,
      subtitle: describe(value),
      body: tree,
      // Reuse the JSON tree CSS — the YAML parser produces the
      // same shape of value tree.
      extraCss: `
.jt-leaf { padding: 1px 0; line-height: 1.55; font-size: 12.5px; }
.jt-key { color: ${CATPPUCCIN.pink}; }
.jt-val[data-type="string"] { color: ${CATPPUCCIN.green}; }
.jt-val[data-type="number"] { color: ${CATPPUCCIN.peach}; }
.jt-val[data-type="boolean"] { color: ${CATPPUCCIN.mauve}; }
.jt-val[data-type="null"] { color: ${CATPPUCCIN.overlay0}; font-style: italic; }
.jt-val[data-type="unknown"] { color: ${CATPPUCCIN.red}; }
.jt-bracket { color: ${CATPPUCCIN.overlay0}; }
details summary {
  cursor: pointer;
  list-style: none;
  padding: 1px 0;
  line-height: 1.55;
  font-size: 12.5px;
}
details summary::-webkit-details-marker { display: none; }
details summary::before {
  content: "▸";
  display: inline-block;
  width: 14px;
  color: ${CATPPUCCIN.overlay0};
  transition: transform 120ms;
}
details[open] summary::before { transform: rotate(90deg); }
details > .jt-children {
  padding-left: 18px;
  border-left: 1px solid ${CATPPUCCIN.surface0};
  margin-left: 6px;
}
.jt-err { color: ${CATPPUCCIN.red}; font-style: italic; }
`,
    }),
});

function describe(v: unknown): string {
  if (Array.isArray(v)) return `array · ${v.length} item${v.length === 1 ? "" : "s"}`;
  if (v && typeof v === "object")
    return `mapping · ${Object.keys(v as object).length} key${
      Object.keys(v as object).length === 1 ? "" : "s"
    }`;
  return typeof v;
}

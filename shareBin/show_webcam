#!/usr/bin/env bun
/**
 * τ-mux — show_webcam
 *
 * Stream the system webcam as a full-pane sideband image panel via
 * ffmpeg + AVFoundation (macOS) / V4L2 (Linux). Frames are pushed
 * as MJPEG over fd4 at the requested output framerate; the image
 * letterboxes inside the panel (the built-in `image` renderer uses
 * `object-fit: contain`) so resizing the terminal preserves the
 * camera aspect ratio.
 *
 * The `getUserMedia` approach used by older versions doesn't work
 * in the bundled webview (camera permission is never granted to
 * the embedded webview); ffmpeg goes through the OS-level Camera
 * permission instead, which the user can grant once and reuse.
 *
 * Usage:
 *   show_webcam                                 # default camera (index 0)
 *   show_webcam --list                          # list available cameras
 *   show_webcam --camera 1                      # camera by index
 *   show_webcam --size 1280x720                 # capture resolution
 *   show_webcam --fps 30 --fps-out 15           # capture / output framerate
 *
 * Quit:
 *   - press q or Ctrl-C while the panel is active
 *   - or send SIGINT/SIGTERM to the script
 */

import { ht } from "./hyperterm";
import { attachFullScreen, viewportSize } from "./lib/full-screen";
import { parseArgs } from "./lib/cli";

let parsed;
try {
  parsed = parseArgs(process.argv.slice(2), {
    schema: [
      { name: "list", long: "list", kind: "boolean", default: false },
      { name: "camera", long: "camera", kind: "string", default: "0" },
      { name: "size", long: "size", kind: "string", default: "640x480" },
      { name: "fps", long: "fps", kind: "string", default: "30" },
      { name: "fpsOut", long: "fps-out", kind: "string", default: "" },
    ] as const,
  });
} catch (err) {
  console.error(`show_webcam: ${(err as Error).message}`);
  process.exit(1);
}

const { flags } = parsed;
const fpsOut = parseInt(flags.fpsOut || flags.fps, 10);
const minFrameInterval = Math.max(15, Math.round(1000 / Math.max(1, fpsOut)));

// ── --list works without τ-mux so users can discover cameras ──

if (flags.list) {
  console.log("Listing available cameras (via ffmpeg AVFoundation)…\n");
  const proc = Bun.spawn(
    ["ffmpeg", "-f", "avfoundation", "-list_devices", "true", "-i", ""],
    { stderr: "pipe", stdout: "pipe" },
  );
  const stderrText = await new Response(proc.stderr).text();
  await proc.exited;

  let inVideo = false;
  for (const line of stderrText.split("\n")) {
    if (line.includes("AVFoundation video devices:")) {
      inVideo = true;
      console.log("Video devices:");
      continue;
    }
    if (line.includes("AVFoundation audio devices:")) break;
    if (inVideo && line.includes("]")) {
      const match = line.match(/\[(\d+)\]\s+(.+)/);
      if (match) console.log(`  ${match[1]}: ${match[2]}`);
    }
  }
  console.log("\nUsage: show_webcam --camera <index>");
  process.exit(0);
}

if (!ht.available) {
  console.error(
    "show_webcam: not running inside τ-mux.\n" +
      "Run it inside the τ-mux terminal emulator. Use --list to see cameras.",
  );
  process.exit(1);
}

// ── Spawn ffmpeg ──

const ffmpeg = Bun.spawn(
  [
    "ffmpeg",
    "-f",
    "avfoundation",
    "-framerate",
    flags.fps,
    "-video_size",
    flags.size,
    "-i",
    `${flags.camera}:none`,
    "-f",
    "image2pipe",
    "-vcodec",
    "mjpeg",
    "-q:v",
    "5",
    "-an",
    "pipe:1",
  ],
  { stdout: "pipe", stderr: "pipe" },
);

// Capture stderr so we can replay the tail when ffmpeg dies before
// emitting any frames (camera permission denied, device busy, …).
// Without this the script just sits with a black panel forever.
const stderrBuf: string[] = [];
const stderrDrained = (async () => {
  const r = ffmpeg.stderr.getReader();
  const d = new TextDecoder();
  try {
    while (true) {
      const { value, done } = await r.read();
      if (done) break;
      stderrBuf.push(d.decode(value, { stream: true }));
      let total = stderrBuf.reduce((n, s) => n + s.length, 0);
      while (total > 32768 && stderrBuf.length > 1) {
        total -= stderrBuf.shift()!.length;
      }
    }
  } catch {
    /* stream ended */
  }
})();

// ── Panel lifecycle via the shared full-screen helper ──

const PANEL_ID = `webcam_${process.pid}_${Date.now().toString(36)}`;

let panelCreated = false;
let latestFrame: Uint8Array | null = null;
let sending = false;
let capturedCount = 0;

// `attachFullScreen` installs the listeners (terminal resize,
// SIGINT/SIGTERM/SIGHUP, error, close) and gives us `size()` and
// `exit()`. We register it BEFORE spawning the panel so the
// post-creation `__terminal__` resize event is captured.
const handle = attachFullScreen({
  panelId: PANEL_ID,
  initialSize: viewportSize(),
  onResize: (size) => {
    if (!panelCreated) return;
    // The image renderer uses object-fit: contain, so the JPEG
    // letterboxes automatically — we just resize the panel and
    // the next frame fills the new dimensions.
    ht.update(PANEL_ID, { x: 0, y: 0, width: size.width, height: size.height });
  },
  onExit: () => {
    if (sendTimer) clearInterval(sendTimer);
    try {
      ffmpeg.kill();
    } catch {
      /* already gone */
    }
    if (stdinRaw) {
      try {
        process.stdin.setRawMode(false);
        process.stdin.pause();
      } catch {
        /* ignore */
      }
    }
  },
});

// ── Frame extraction (MJPEG: SOI 0xFFD8 → EOI 0xFFD9) ──

function findJpegStart(buf: Uint8Array, start: number): number {
  for (let i = start; i < buf.length - 1; i++) {
    if (buf[i] === 0xff && buf[i + 1] === 0xd8) return i;
  }
  return -1;
}

function findJpegEnd(buf: Uint8Array, start: number): number {
  for (let i = start + 2; i < buf.length - 1; i++) {
    if (buf[i] === 0xff && buf[i + 1] === 0xd9) return i + 2;
  }
  return -1;
}

// ── Timed sender — coalesces captured frames to the output rate ──

const sendTimer = setInterval(() => {
  if (!latestFrame || sending) return;
  sending = true;
  const frame = latestFrame;
  latestFrame = null;

  try {
    const size = handle.size();
    if (!panelCreated) {
      ht.sendMeta({
        id: PANEL_ID,
        type: "image",
        format: "jpeg",
        position: "fixed",
        x: 0,
        y: 0,
        width: size.width,
        height: size.height,
        draggable: false,
        resizable: false,
        interactive: false,
        borderRadius: 0,
        timeout: 30000,
        byteLength: frame.byteLength,
      });
      ht.sendData(frame);
      panelCreated = true;
    } else {
      // `update` with raw bytes routes through the panel's `data`
      // channel and replaces the JPEG. Width/height stay sticky from
      // the last resize so we don't need to repeat them.
      ht.update(PANEL_ID, { data: frame, timeout: 30000 });
    }
  } finally {
    sending = false;
  }
}, minFrameInterval);

// ── Stdin: q / Ctrl-C exit ──
//
// Fixed panels carry no UI chrome → no close button. While the
// webcam is on screen the user's keystrokes go through xterm into
// our stdin (we are the foreground PTY process). Putting stdin in
// raw mode lets a single 'q' or Ctrl-C trigger a clean exit.

let stdinRaw = false;
if (process.stdin.isTTY) {
  try {
    process.stdin.setRawMode(true);
    process.stdin.resume();
    stdinRaw = true;
    process.stdin.on("data", (chunk: Buffer) => {
      for (const byte of chunk) {
        if (byte === 0x71 || byte === 0x51 /* q / Q */ || byte === 0x03 /* ^C */) {
          handle.exit();
        }
      }
    });
  } catch {
    /* not interactive — rely on signals */
  }
}

// ── ffmpeg stdout reader: extract JPEG frames into latestFrame ──

const reader = ffmpeg.stdout.getReader();
let buffer = new Uint8Array(0);

(async () => {
  try {
    while (true) {
      const { value, done } = await reader.read();
      if (done) break;

      if (buffer.length === 0) {
        buffer = value;
      } else {
        const next = new Uint8Array(buffer.length + value.length);
        next.set(buffer);
        next.set(value, buffer.length);
        buffer = next;
      }

      let lastCompleteFrame: Uint8Array | null = null;

      while (true) {
        const soi = findJpegStart(buffer, 0);
        if (soi === -1) {
          buffer = new Uint8Array(0);
          break;
        }
        if (soi > 0) buffer = buffer.slice(soi);
        const eoi = findJpegEnd(buffer, 0);
        if (eoi === -1) break;
        lastCompleteFrame = buffer.slice(0, eoi);
        buffer = buffer.slice(eoi);
        capturedCount++;
      }

      if (lastCompleteFrame) latestFrame = lastCompleteFrame;
    }
  } catch {
    /* stream ended */
  }
})();

// ── ffmpeg exit: surface cause when no frames were captured ──

ffmpeg.exited.then(async () => {
  // If frames did flow, ffmpeg exiting just means EOF on the input
  // — fine, tear down.
  if (capturedCount > 0) {
    handle.exit("ffmpeg exited");
    return;
  }
  // Zero frames → drain the stderr tail (give it 500 ms in case
  // the error landed after the stdout pipe closed) and print it so
  // the user can act on the cause.
  await Promise.race([
    stderrDrained,
    new Promise((r) => setTimeout(r, 500)),
  ]);
  const tail = stderrBuf.join("").slice(-2000);
  process.stderr.write(
    `\n[show_webcam] ffmpeg produced no frames. stderr tail:\n${tail}\n` +
      "\nHints: run `show_webcam --list` to verify the camera index, " +
      "and grant Camera access in System Settings → Privacy & Security " +
      "→ Camera to the app running τ-mux.\n",
  );
  handle.exit("ffmpeg exited with no frames");
});

#!/usr/bin/env bun
/**
 * τ-mux — show_qr
 *
 * Encode a string as a QR code and display the resulting SVG in a
 * full-pane sideband panel. The QR is centered and resized to fit
 * the available space — resizing the terminal grows / shrinks the
 * code.
 *
 * Usage:
 *   show_qr "https://example.com"          # text from argv
 *   echo "secret-token" | show_qr          # piped stdin
 *   show_qr --ec H "https://x.com"         # high error correction
 *   show_qr --scale 8 --margin 4 ...
 *
 * Flags:
 *   --ec L|M|Q|H        error correction level (default M)
 *   --scale N           pixels per QR module (default 6)
 *   --margin N          quiet-zone modules (default 2)
 *   --dark / --light    foreground / background colour
 */

import {
  CATPPUCCIN,
  fullScreenHtml,
  fullScreenPage,
  type FullScreenSize,
} from "./lib/full-screen";
import {
  type ErrorCorrectionLevel,
  encodeQr,
  qrToSvg,
} from "./lib/qr";
import { escapeHtml } from "./lib/escape";
import { parseArgs, readInput } from "./lib/cli";

let parsed;
try {
  parsed = parseArgs(process.argv.slice(2), {
    schema: [
      { name: "ec", long: "ec", kind: "string", default: "M" },
      { name: "scale", long: "scale", kind: "number", default: 6 },
      { name: "margin", long: "margin", kind: "number", default: 2 },
      { name: "dark", long: "dark", kind: "string", default: "#0b1020" },
      { name: "light", long: "light", kind: "string", default: "#ffffff" },
    ] as const,
  });
} catch (err) {
  console.error(`show_qr: ${(err as Error).message}`);
  process.exit(1);
}

const { positional, flags } = parsed;

let payload: string;
if (positional.length > 0) {
  payload = positional.join(" ");
} else {
  payload = readInput("", {
    utility: "show_qr",
    expecting: "text to encode",
  }).replace(/\n+$/, "");
}

const ec = flags.ec.toUpperCase() as ErrorCorrectionLevel;
if (!["L", "M", "Q", "H"].includes(ec)) {
  console.error(`show_qr: invalid --ec "${flags.ec}" (use L, M, Q, or H)`);
  process.exit(1);
}

let svg: string;
try {
  const qr = encodeQr(payload, { ecLevel: ec });
  svg = qrToSvg(qr, {
    scale: flags.scale,
    margin: flags.margin,
    dark: flags.dark,
    light: flags.light,
  });
} catch (err) {
  console.error(`show_qr: ${(err as Error).message}`);
  process.exit(1);
}

const preview = payload.length > 80 ? `${payload.slice(0, 77)}…` : payload;

function renderPage(_size: FullScreenSize): string {
  return fullScreenPage({
    tag: { label: `QR · ${ec}`, color: CATPPUCCIN.yellow },
    title: escapeHtml(preview),
    subtitle: `${payload.length} char${payload.length === 1 ? "" : "s"}`,
    body: `<div class="qr-frame">${svg}</div><div class="qr-payload">${escapeHtml(payload)}</div>`,
    extraCss: `
.fs-body { padding: 24px; display: flex; flex-direction: column; gap: 18px; align-items: center; min-height: 0; }
.qr-frame {
  flex: 1 1 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  background: ${flags.light};
  padding: 24px;
  border-radius: 14px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.45);
  min-height: 0;
  width: min(100%, 80vh);
  aspect-ratio: 1 / 1;
}
.qr-frame svg { display: block; width: 100%; height: 100%; }
.qr-payload {
  flex: 0 0 auto;
  max-width: 100%;
  max-height: 5em;
  overflow: auto;
  word-break: break-all;
  font-size: 11px;
  color: ${CATPPUCCIN.subtext0};
  text-align: center;
  line-height: 1.5;
  padding: 6px 12px;
  background: ${CATPPUCCIN.mantle};
  border-radius: 6px;
  border: 1px solid ${CATPPUCCIN.surface0};
}
`,
  });
}

fullScreenHtml({ render: renderPage });

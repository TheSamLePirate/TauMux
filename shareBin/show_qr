#!/usr/bin/env bun
/**
 * τ-mux — show_qr
 *
 * Encode a string as a QR code and display the resulting SVG in a
 * sideband panel.
 *
 * Usage:
 *   show_qr "https://example.com"          # text from argv
 *   echo "secret-token" | show_qr          # piped stdin
 *   show_qr --ec H "https://x.com"         # high error correction
 *   show_qr --scale 8 --margin 4 ...
 *
 * Flags:
 *   --ec L|M|Q|H        error correction level (default M)
 *   --scale N           pixels per QR module (default 6)
 *   --margin N          quiet-zone modules (default 2)
 *   --dark / --light    foreground / background colour
 *   --inline            position panel inline at the cursor
 *   --x N --y N         explicit position
 *   --width N           panel pixel width (panel chrome only;
 *                        the SVG sizes itself)
 *   --no-wait           exit after creating the panel
 */

import { ht } from "./hyperterm";
import {
  type ErrorCorrectionLevel,
  encodeQr,
  qrToSvg,
} from "./lib/qr";
import { escapeHtml } from "./lib/escape";
import { PANEL_FLAGS, parseArgs, readInput } from "./lib/cli";

if (!ht.available) {
  console.error("show_qr: not running inside τ-mux.");
  process.exit(1);
}

let parsed;
try {
  parsed = parseArgs(process.argv.slice(2), {
    schema: [
      ...PANEL_FLAGS,
      { name: "ec", long: "ec", kind: "string", default: "M" },
      { name: "scale", long: "scale", kind: "number", default: 6 },
      { name: "margin", long: "margin", kind: "number", default: 2 },
      { name: "dark", long: "dark", kind: "string", default: "#0b1020" },
      { name: "light", long: "light", kind: "string", default: "#ffffff" },
    ] as const,
  });
} catch (err) {
  console.error(`show_qr: ${(err as Error).message}`);
  process.exit(1);
}

const { positional, flags } = parsed;

// Two input modes:
//   - positional arg → encode the literal string (URLs / tokens)
//   - piped stdin    → encode the piped text
// We prefer the positional arg so `show_qr "$(cat file)"` works.
let payload: string;
if (positional.length > 0) {
  payload = positional.join(" ");
} else {
  payload = readInput("", {
    utility: "show_qr",
    expecting: "text to encode",
  }).replace(/\n+$/, "");
}

const ec = flags.ec.toUpperCase() as ErrorCorrectionLevel;
if (!["L", "M", "Q", "H"].includes(ec)) {
  console.error(`show_qr: invalid --ec "${flags.ec}" (use L, M, Q, or H)`);
  process.exit(1);
}

let svg: string;
try {
  const qr = encodeQr(payload, { ecLevel: ec });
  svg = qrToSvg(qr, {
    scale: flags.scale,
    margin: flags.margin,
    dark: flags.dark,
    light: flags.light,
  });
} catch (err) {
  console.error(`show_qr: ${(err as Error).message}`);
  process.exit(1);
}

const preview = payload.length > 64 ? `${payload.slice(0, 61)}...` : payload;

const html = `<div class="qr-pane">
  <header><span class="qr-tag">QR / ${ec}</span><span class="qr-text">${escapeHtml(preview)}</span></header>
  <div class="qr-frame">${svg}</div>
</div>
<style>
  body { margin: 0; }
  .qr-pane {
    font-family: ui-monospace, SF Mono, "JetBrains Mono", monospace;
    font-size: 11px;
    color: #d6d8dc;
    background: rgba(20, 24, 30, 0.97);
    padding: 10px 14px 14px;
    border-radius: 10px;
    height: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .qr-pane header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: baseline;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding-bottom: 6px;
    letter-spacing: 0.04em;
  }
  .qr-tag { color: #f9e2af; font-weight: 600; }
  .qr-text {
    color: #9aa0a6;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1 1 auto;
    min-width: 0;
  }
  .qr-frame {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    border-radius: 6px;
    padding: 12px;
    overflow: hidden;
  }
  .qr-frame svg { max-width: 100%; max-height: 100%; height: auto; }
</style>`;

const panelId = ht.showHtml(html, {
  position: flags.inline ? "inline" : "float",
  x: flags.x,
  y: flags.y,
  width: flags.width,
  height: flags.height,
  draggable: true,
  resizable: true,
});

if (!flags.noWait) {
  await ht.waitForClose(panelId).catch(() => {});
}

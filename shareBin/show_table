#!/usr/bin/env bun
/**
 * τ-mux — show_table
 *
 * Render CSV / TSV as a sortable HTML table in a sideband panel.
 * Click any column header to sort ascending; click again for
 * descending; click a third time to restore the original order.
 * Numeric columns sort numerically; everything else sorts
 * lexicographically.
 *
 * Usage:
 *   show_table data.csv                    # render a file
 *   ps aux | show_table --tsv              # piped, tab-sep
 *   show_table --no-header data.csv        # treat row 0 as data
 *
 * Flags:
 *   --tsv             force tab separator
 *   --csv             force comma separator (default = auto-sniff)
 *   --no-header       treat every row as body (no <thead>)
 *   --inline          position panel inline at the cursor
 *   --x N --y N       explicit position
 *   --width N         panel width (default 720)
 *   --no-wait         exit immediately after creating the panel
 */

import { readFileSync } from "node:fs";
import { ht } from "./hyperterm";
import { parseCsv } from "./lib/csv";
import { renderTable } from "./lib/table";
import { escapeHtml } from "./lib/escape";

if (!ht.available) {
  console.error("show_table: not running inside τ-mux.");
  process.exit(1);
}

const argv = process.argv.slice(2);
const flags = { inline: false, noWait: false, noHeader: false };
let sep: "," | "\t" | "auto" = "auto";
let x = 80;
let y = 80;
let width = 720;
let path = "";
for (let i = 0; i < argv.length; i++) {
  const a = argv[i]!;
  if (a === "--inline") flags.inline = true;
  else if (a === "--no-wait") flags.noWait = true;
  else if (a === "--no-header") flags.noHeader = true;
  else if (a === "--tsv") sep = "\t";
  else if (a === "--csv") sep = ",";
  else if (a === "--x") x = parseInt(argv[++i] ?? "80", 10);
  else if (a === "--y") y = parseInt(argv[++i] ?? "80", 10);
  else if (a === "--width") width = parseInt(argv[++i] ?? "720", 10);
  else if (!path) path = a;
}

let raw: string;
if (path) {
  try {
    raw = readFileSync(path, "utf8");
  } catch (err) {
    console.error(
      `show_table: cannot read ${path}: ${(err as Error).message}`,
    );
    process.exit(1);
  }
} else if (!process.stdin.isTTY) {
  raw = readFileSync(0, "utf8");
} else {
  console.error(
    "show_table: no input — pass a file path or pipe CSV/TSV into stdin",
  );
  process.exit(1);
}

const rows = parseCsv(raw, { sep });
const title = path ? escapeHtml(path) : "stdin";
const tableHtml = renderTable(rows, {
  hasHeader: !flags.noHeader,
  title,
});
const html = `${tableHtml}
<style>
  body { margin: 0; font-family: ui-monospace, SF Mono, "JetBrains Mono", monospace; }
  .tbl-pane {
    color: #d6d8dc;
    background: rgba(20, 24, 30, 0.97);
    border-radius: 10px;
    height: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    font-size: 12px;
  }
  .tbl-pane > header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 10px 14px 8px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    color: #66c0f4;
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .tbl-pane > header .tbl-count {
    color: #6c7086;
  }
  .tbl-scroll { overflow: auto; flex: 1 1 auto; min-height: 0; }
  table.tbl {
    width: 100%;
    border-collapse: collapse;
  }
  table.tbl thead th {
    position: sticky;
    top: 0;
    background: rgba(20, 24, 30, 0.98);
    color: #ecedef;
    text-align: left;
    padding: 8px 12px;
    font-weight: 600;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  table.tbl thead th:hover {
    background: rgba(102, 192, 244, 0.08);
  }
  .tbl-sort {
    margin-left: 6px;
    color: #6c7086;
    font-size: 10px;
  }
  table.tbl tbody td {
    padding: 5px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    line-height: 1.45;
    vertical-align: top;
    overflow-wrap: anywhere;
  }
  table.tbl tbody tr:nth-child(odd) td {
    background: rgba(255,255,255,0.012);
  }
  table.tbl tbody tr:hover td {
    background: rgba(102, 192, 244, 0.06);
  }
  .tbl-empty {
    padding: 16px;
    color: #6c7086;
    font-style: italic;
  }
</style>`;

const panelId = ht.showHtml(html, {
  position: flags.inline ? "inline" : "float",
  x,
  y,
  width,
  height: 480,
  draggable: true,
  resizable: true,
});

if (!flags.noWait) {
  await ht.waitForClose(panelId).catch(() => {});
}

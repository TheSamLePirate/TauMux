#!/usr/bin/env bun
/**
 * τ-mux — show_table
 *
 * Render CSV / TSV as a sortable HTML table in a full-pane
 * sideband panel. Click any column header to sort ascending; click
 * again for descending; click a third time to restore the original
 * order. Numeric columns sort numerically; everything else sorts
 * lexicographically.
 *
 * The panel is pinned to the host pane, follows terminal resizes,
 * and exits when the user closes it.
 *
 * Usage:
 *   show_table data.csv                    # render a file
 *   ps aux | show_table --tsv              # piped, tab-sep
 *   show_table --no-header data.csv        # treat row 0 as data
 *
 * Flags:
 *   --tsv             force tab separator
 *   --csv             force comma separator (default = auto-sniff)
 *   --no-header       treat every row as body (no <thead>)
 */

import {
  CATPPUCCIN,
  fullScreenHtml,
  fullScreenPage,
} from "./lib/full-screen";
import { parseCsv } from "./lib/csv";
import { renderTable } from "./lib/table";
import { escapeHtml } from "./lib/escape";
import { readInput } from "./lib/cli";

const argv = process.argv.slice(2);
const sep: "," | "\t" | "auto" = argv.includes("--tsv")
  ? "\t"
  : argv.includes("--csv")
    ? ","
    : "auto";
const noHeader = argv.includes("--no-header");
const path = argv.find((a) => !a.startsWith("--")) ?? "";

const raw = readInput(path, { utility: "show_table", expecting: "CSV/TSV" });
const rows = parseCsv(raw, { sep });
const titleLabel = path ? escapeHtml(path) : "stdin";
const tableHtml = renderTable(rows, { hasHeader: !noHeader });
const bodyRowCount = noHeader ? rows.length : Math.max(0, rows.length - 1);
const colCount = rows.reduce((m, r) => Math.max(m, r.length), 0);

fullScreenHtml({
  render: () =>
    fullScreenPage({
      tag: { label: "TABLE", color: CATPPUCCIN.teal },
      title: titleLabel,
      subtitle: `${bodyRowCount} row${bodyRowCount === 1 ? "" : "s"} · ${colCount} col${colCount === 1 ? "" : "s"}`,
      body: tableHtml,
      extraCss: `
.fs-body { padding: 0; }
.tbl-pane { height: 100%; display: flex; flex-direction: column; }
.tbl-empty { padding: 18px; color: ${CATPPUCCIN.overlay0}; font-style: italic; }
.tbl-scroll { overflow: auto; flex: 1 1 auto; min-height: 0; }
table.tbl { width: 100%; border-collapse: collapse; }
table.tbl thead th {
  position: sticky; top: 0;
  background: ${CATPPUCCIN.mantle};
  color: ${CATPPUCCIN.text};
  text-align: left;
  padding: 9px 14px;
  font-weight: 600;
  border-bottom: 1px solid ${CATPPUCCIN.surface1};
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}
table.tbl thead th:hover { background: ${CATPPUCCIN.surface0}; }
.tbl-sort { margin-left: 6px; color: ${CATPPUCCIN.overlay0}; font-size: 10px; }
table.tbl tbody td {
  padding: 6px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.03);
  line-height: 1.45;
  vertical-align: top;
  overflow-wrap: anywhere;
}
table.tbl tbody tr:nth-child(odd) td { background: rgba(255,255,255,0.012); }
table.tbl tbody tr:hover td { background: rgba(137, 180, 250, 0.08); }
`,
    }),
});

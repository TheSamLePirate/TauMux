let firstFailureLogged = false;

function runHt(args: string[]): boolean {
  const res = spawnSync(HT, args, { encoding: "utf-8" });
  if (res.error) {
    process.stderr.write(
      `[demo_status_keys] spawn ${HT} failed: ${res.error.message}\n`,
    );
    return false;
  }
  if (res.status === 0) return true;
  // Surface the *first* failure with full context so the user can see
  // why (no socket, allow-list, etc.). Subsequent failures stay
  // compact so the log isn't overwhelmed.
  const stderr = (res.stderr ?? "").trim();
  const stdout = (res.stdout ?? "").trim();
  if (!firstFailureLogged) {
    firstFailureLogged = true;
    process.stderr.write(
      `[demo_status_keys] ht ${args.join(" ")} → exit ${res.status}\n`,
    );
    if (stderr) process.stderr.write(`  stderr: ${stderr}\n`);
    if (stdout) process.stderr.write(`  stdout: ${stdout}\n`);
    process.stderr.write(
      `  (subsequent failures collapsed to one line each)\n`,
    );
  } else {
    process.stderr.write(
      `[demo_status_keys] ht ${args[0]} ${args[1]} → exit ${res.status}${stderr ? ` (${stderr.split("\n")[0]})` : ""}\n`,
    );
  }
  return false;
}

function setEntry(e: DemoEntry): boolean {
  const args = ["set-status", e.key, e.value];
  if (e.icon) args.push("--icon", e.icon);
  if (e.color) args.push("--color", e.color);
  return runHt(args);
}

function main(): void {
  const argv = process.argv.slice(2);
  process.stdout.write(`[demo_status_keys] using ${HT}\n`);

  if (argv.includes("--clear")) {
    let ok = 0;
    for (const e of DEMOS) if (runHt(["clear-status", e.key])) ok++;
    process.stdout.write(
      `Cleared ${ok}/${DEMOS.length} demo keys.${ok === DEMOS.length ? "" : " (some clears failed — see above)"}\n`,
    );
    return;
  }

  let ok = 0;
  for (const e of DEMOS) if (setEntry(e)) ok++;
  process.stdout.write(
    `Set ${ok}/${DEMOS.length} demo status keys. Open the sidebar workspace ` +
      `card or enable "ht: all statuses" in the bottom bar.\n` +
      `Run with --clear to remove. Run with --live to animate.\n`,
  );

  if (argv.includes("--live")) {
    process.stdout.write("Live mode — Ctrl-C to stop.\n");
    const tickable = DEMOS.filter((e) => typeof e.tick === "function");
    const tick = () => {
      for (const e of tickable) {
        if (!e.tick) continue;
        setEntry({ ...e, value: e.tick() });
      }
    };
    setInterval(tick, 1500);
  }
}

main();

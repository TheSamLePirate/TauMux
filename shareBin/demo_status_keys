#!/usr/bin/env bun
/**
 * τ-mux — demo_status_keys
 *
 * Exercise every renderer in the smart status-key DSL (Plan #02 v2):
 *
 *   numeric:  text · longtext · code · num · count · pct · bytes · ms
 *             duration · currency · rating
 *   time:     time · eta · date · clock
 *   state:    bool · status · dot · badge
 *   chart:    bar · vbar · gauge · lineGraph · sparkline · area
 *             histogram · heatmap · dotGraph · pie · donut
 *   data:     array · kv · json · list · tags
 *   rich:     link · image · md · color · kbd · file
 *
 * Each call goes through `ht set-status` so the entries appear in:
 *   1. the sidebar workspace card (block layouts where applicable)
 *   2. the bottom status bar via `ht-all` (always inline)
 *   3. the Settings → Layout → Discovered ht keys list
 *
 * Pass `--clear` to remove every demo key. Pass `--live` to keep the
 * line-graph / vbar / area renderers ticking with random samples
 * until you Ctrl-C — useful for visual smoke-testing.
 *
 * Usage:
 *   shareBin/demo_status_keys
 *   shareBin/demo_status_keys --live
 *   shareBin/demo_status_keys --clear
 */

import { spawnSync } from "node:child_process";
import { existsSync } from "node:fs";
import { resolve } from "node:path";

/** Locate the `ht` binary across every layout τ-mux ships in:
 *
 *   1. **Packaged .app** — script lives at
 *      `<App>/Contents/Resources/app/shareBin/`; the standalone
 *      Mach-O `ht` that the post-build hook produces is at
 *      `<App>/Contents/MacOS/ht`. There is no `bin/` here.
 *   2. **Dev checkout** — script lives at `<repo>/shareBin/`; the
 *      bun-shebanged `ht` lives at `<repo>/bin/ht`.
 *   3. **Installed dotfile / weird PATH layout** — fall back to
 *      whatever `which ht` resolves to.
 *
 *  Returning a single absolute path keeps `spawnSync` deterministic
 *  regardless of cwd. */
function locateHt(): string {
  const here = import.meta.dir;
  const candidates: string[] = [];

  // (1) Packaged .app — walk up from `Contents/Resources/app/shareBin`
  // to `Contents/MacOS/ht`. Three levels up lands on `Contents/`.
  if (here.includes("Contents/Resources/app")) {
    candidates.push(resolve(here, "..", "..", "..", "MacOS", "ht"));
  }
  // (2) Dev checkout — `<repo>/shareBin/..` is the repo root.
  candidates.push(resolve(here, "..", "bin", "ht"));

  for (const c of candidates) if (existsSync(c)) return c;

  // (3) PATH lookup as a last resort.
  const which = spawnSync("which", ["ht"], { encoding: "utf-8" });
  const path = which.stdout.trim();
  if (path) return path;

  process.stderr.write(
    "[demo_status_keys] could not locate `ht`.\n" +
      `  tried: ${candidates.join(", ")}\n` +
      "  also tried `which ht` — not found.\n" +
      "  Install the CLI via the τ-mux app menu, or run from the repo checkout.\n",
  );
  process.exit(1);
}

const HT = locateHt();


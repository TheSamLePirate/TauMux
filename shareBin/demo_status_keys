#!/usr/bin/env bun
/**
 * τ-mux — demo_status_keys
 *
 * Exercise every renderer in the smart status-key DSL (Plan #02 v2):
 *
 *   numeric:  text · longtext · code · num · count · pct · bytes · ms
 *             duration · currency · rating
 *   time:     time · eta · date · clock
 *   state:    bool · status · dot · badge
 *   chart:    bar · vbar · gauge · lineGraph · sparkline · area
 *             histogram · heatmap · dotGraph · pie · donut
 *   data:     array · kv · json · list · tags
 *   rich:     link · image · md · color · kbd · file
 *
 * Each call goes through `ht set-status` so the entries appear in:
 *   1. the sidebar workspace card (block layouts where applicable)
 *   2. the bottom status bar via `ht-all` (always inline)
 *   3. the Settings → Layout → Discovered ht keys list
 *
 * Pass `--clear` to remove every demo key. Pass `--live` to keep the
 * line-graph / vbar / area renderers ticking with random samples
 * until you Ctrl-C — useful for visual smoke-testing.
 *
 * Usage:
 *   shareBin/demo_status_keys
 *   shareBin/demo_status_keys --live
 *   shareBin/demo_status_keys --clear
 */

import { spawnSync } from "node:child_process";
import { existsSync } from "node:fs";
import { resolve } from "node:path";

/** Prefer the repo's `bin/ht` (matches the running τ-mux build), fall
 *  back to a `ht` resolved via `PATH` when the script is launched from
 *  somewhere other than a checkout (e.g. an installed dotfile). */
function locateHt(): string {
  const repoBin = resolve(import.meta.dir, "..", "bin", "ht");
  if (existsSync(repoBin)) return repoBin;
  const which = spawnSync("which", ["ht"], { encoding: "utf-8" });
  const path = which.stdout.trim();
  if (path) return path;
  process.stderr.write(
    "[demo_status_keys] could not locate `ht` — install it via the τ-mux app menu or run from the repo.\n",
  );
  process.exit(1);
}

const HT = locateHt();


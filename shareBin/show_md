#!/usr/bin/env bun
/**
 * τ-mux — show_md
 *
 * Live markdown previewer in a full-pane sideband panel. Renders
 * with the bundled subset (`lib/markdown.ts`) — heading levels 1-4,
 * fenced code, lists, links, inline emphasis. Watches the file's
 * mtime and re-renders on change. Resizes with the terminal,
 * exits when the panel is closed.
 *
 * Usage:
 *   show_md README.md
 *   show_md --no-watch CHANGELOG.md     # one-shot, no polling
 *   show_md - < some.md                 # read from stdin (no watcher)
 *
 * Flags:
 *   --no-watch          render once, don't poll mtime
 *   --interval N        ms between mtime checks (default 500)
 */

import { readFileSync, statSync } from "node:fs";
import {
  CATPPUCCIN,
  fullScreenHtml,
  fullScreenPage,
  type FullScreenSize,
} from "./lib/full-screen";
import { renderMarkdown } from "./lib/markdown";
import { escapeHtml } from "./lib/escape";
import { parseArgs } from "./lib/cli";

let parsed;
try {
  parsed = parseArgs(process.argv.slice(2), {
    schema: [
      { name: "noWatch", long: "no-watch", kind: "boolean", default: false },
      { name: "interval", long: "interval", kind: "number", default: 500 },
    ] as const,
  });
} catch (err) {
  console.error(`show_md: ${(err as Error).message}`);
  process.exit(1);
}

const { positional, flags } = parsed;
const path = positional[0] ?? "";
if (!path) {
  console.error("Usage: show_md <file.md>  [--no-watch]");
  process.exit(1);
}

const isStdin = path === "-";
const fileLabel = isStdin ? "stdin" : path;
const titleLabel = escapeHtml(fileLabel);

let markdown = readSource();
let lastModified = currentMtime();

function currentMtime(): number {
  if (isStdin) return Date.now();
  try {
    const s = statSync(path);
    return typeof s.mtimeMs === "number" ? s.mtimeMs : s.mtime.getTime();
  } catch {
    return 0;
  }
}

function readSource(): string {
  try {
    return isStdin ? readFileSync(0, "utf8") : readFileSync(path, "utf8");
  } catch (err) {
    return `# Error reading ${fileLabel}\n\n\`\`\`\n${(err as Error).message}\n\`\`\``;
  }
}

function renderPage(_size: FullScreenSize): string {
  const stamp = formatTime(new Date(lastModified));
  return fullScreenPage({
    tag: { label: "MARKDOWN", color: CATPPUCCIN.green },
    title: titleLabel,
    subtitle: isStdin ? "stdin" : `modified ${stamp}`,
    body: `<article class="md-body">${renderMarkdown(markdown)}</article>`,
    extraCss: `
.fs-body { padding: 0; }
.md-body {
  max-width: 880px;
  margin: 0 auto;
  padding: 28px 32px 64px;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 15px;
  line-height: 1.65;
  color: ${CATPPUCCIN.text};
}
.md-body h1, .md-body h2, .md-body h3, .md-body h4 {
  color: ${CATPPUCCIN.lavender};
  font-weight: 700;
  margin: 1.6em 0 0.6em;
  line-height: 1.3;
}
.md-body h1 { font-size: 28px; border-bottom: 1px solid ${CATPPUCCIN.surface1}; padding-bottom: 10px; }
.md-body h2 { font-size: 22px; }
.md-body h3 { font-size: 18px; }
.md-body h4 { font-size: 15px; color: ${CATPPUCCIN.blue}; }
.md-body p { margin: 0 0 1em; }
.md-body strong { color: ${CATPPUCCIN.text}; font-weight: 700; }
.md-body em { color: ${CATPPUCCIN.subtext1}; }
.md-body a { color: ${CATPPUCCIN.blue}; text-decoration: underline; text-underline-offset: 2px; }
.md-body a:hover { color: ${CATPPUCCIN.lavender}; }
.md-body ul, .md-body ol { margin: 0 0 1em 1.4em; padding: 0; }
.md-body li { margin: 0.25em 0; }
.md-body code {
  font-family: ui-monospace, "SF Mono", "JetBrains Mono", monospace;
  font-size: 0.9em;
  background: ${CATPPUCCIN.mantle};
  border: 1px solid ${CATPPUCCIN.surface0};
  color: ${CATPPUCCIN.peach};
  padding: 1px 6px;
  border-radius: 4px;
}
.md-body pre {
  background: ${CATPPUCCIN.mantle};
  border: 1px solid ${CATPPUCCIN.surface0};
  border-radius: 8px;
  padding: 14px 16px;
  margin: 1em 0;
  overflow-x: auto;
  line-height: 1.5;
}
.md-body pre code {
  background: transparent;
  border: 0;
  padding: 0;
  font-size: 13px;
  color: ${CATPPUCCIN.text};
}
`,
  });
}

const panel = fullScreenHtml({
  render: renderPage,
  onExit: () => {
    if (watchTimer) clearInterval(watchTimer);
  },
});

let watchTimer: ReturnType<typeof setInterval> | null = null;
if (!isStdin && !flags.noWatch) {
  watchTimer = setInterval(() => {
    const mtime = currentMtime();
    if (mtime === lastModified) return;
    lastModified = mtime;
    markdown = readSource();
    panel.rerender();
  }, Math.max(100, flags.interval));
}

function formatTime(d: Date): string {
  const pad = (n: number) => n.toString().padStart(2, "0");
  return `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
}

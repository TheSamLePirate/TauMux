#!/usr/bin/env bun
/**
 * τ-mux — show_img
 *
 * Display an image file as a full-pane sideband panel. The panel
 * is pinned to the host pane, follows terminal resizes, and exits
 * the moment the user closes it.
 *
 * Aspect ratio is preserved — the image is drawn centered on a
 * dark backdrop with `object-fit: contain` so resizing the pane
 * never distorts it.
 *
 * Usage:
 *   show_img <image_path>
 */

import { readFileSync, statSync } from "node:fs";
import { ht } from "./hyperterm";
import {
  CATPPUCCIN,
  fullScreenHtml,
  type FullScreenSize,
} from "./lib/full-screen";
import { escapeHtml } from "./lib/escape";

if (!ht.available) {
  console.error("show_img: not running inside τ-mux.");
  process.exit(1);
}

const argv = process.argv.slice(2);
const path = argv.find((a) => !a.startsWith("--")) ?? "";

if (!path) {
  console.error("Usage: show_img <image_path>");
  process.exit(1);
}

// Guard against absurdly large images — embedded as a data: URI
// so the whole payload sits in the panel HTML. 50 MB matches the
// previous Python implementation's cap.
const MAX_BYTES = 50 * 1024 * 1024;
let size: number;
try {
  size = statSync(path).size;
} catch (err) {
  console.error(`show_img: cannot stat ${path}: ${(err as Error).message}`);
  process.exit(1);
}
if (size > MAX_BYTES) {
  console.error(
    `show_img: refusing to display ${path} — ${size} bytes exceeds ${MAX_BYTES} byte cap.`,
  );
  process.exit(1);
}

const ext = path.split(".").pop()?.toLowerCase() ?? "png";
const mimeMap: Record<string, string> = {
  png: "image/png",
  jpg: "image/jpeg",
  jpeg: "image/jpeg",
  gif: "image/gif",
  webp: "image/webp",
  svg: "image/svg+xml",
  bmp: "image/bmp",
};
const mime = mimeMap[ext] ?? "image/png";

let bytes: Buffer;
try {
  bytes = readFileSync(path);
} catch (err) {
  console.error(`show_img: cannot read ${path}: ${(err as Error).message}`);
  process.exit(1);
}
const dataUri = `data:${mime};base64,${bytes.toString("base64")}`;
const titleLabel = escapeHtml(path);
const sizeLabel = formatBytes(size);

function renderPage(_size: FullScreenSize): string {
  return `<div class="im-shell">
  <header class="im-header">
    <span class="im-tag">IMAGE</span>
    <span class="im-title">${titleLabel}</span>
    <span class="im-spacer"></span>
    <span class="im-meta">${mime} · ${sizeLabel}</span>
  </header>
  <div class="im-frame">
    <img src="${dataUri}" alt="${titleLabel}"/>
  </div>
</div>
<style>
*, *::before, *::after { box-sizing: border-box; }
html, body { margin: 0; padding: 0; width: 100%; height: 100%; background: ${CATPPUCCIN.crust}; color: ${CATPPUCCIN.text}; font-family: ui-monospace, "SF Mono", "JetBrains Mono", monospace; font-size: 12.5px; overflow: hidden; }
.im-shell { display: flex; flex-direction: column; width: 100%; height: 100%; }
.im-header {
  flex: 0 0 auto;
  display: flex;
  gap: 14px;
  align-items: center;
  padding: 10px 18px;
  border-bottom: 1px solid ${CATPPUCCIN.surface0};
  background: ${CATPPUCCIN.mantle};
  font-size: 11.5px;
  letter-spacing: 0.04em;
}
.im-tag { color: ${CATPPUCCIN.pink}; font-weight: 700; text-transform: uppercase; }
.im-title { color: ${CATPPUCCIN.text}; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.im-spacer { flex: 1 1 auto; }
.im-meta { color: ${CATPPUCCIN.overlay1}; font-variant-numeric: tabular-nums; }
.im-frame {
  flex: 1 1 auto;
  min-height: 0;
  background:
    linear-gradient(45deg, ${CATPPUCCIN.crust} 25%, transparent 25%),
    linear-gradient(-45deg, ${CATPPUCCIN.crust} 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, ${CATPPUCCIN.crust} 75%),
    linear-gradient(-45deg, transparent 75%, ${CATPPUCCIN.crust} 75%);
  background-color: ${CATPPUCCIN.mantle};
  background-size: 18px 18px;
  background-position: 0 0, 0 9px, 9px -9px, -9px 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  overflow: hidden;
}
.im-frame img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.45));
}
</style>`;
}

fullScreenHtml({ render: renderPage });

function formatBytes(n: number): string {
  if (n < 1024) return `${n} B`;
  if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
  return `${(n / 1024 / 1024).toFixed(2)} MB`;
}

{
  "name": "hyperterm-canvas",
  "version": "0.0.2",
  "type": "module",
  "description": "A hybrid terminal emulator with structured rendering channels",
  "bin": {
    "ht": "bin/ht"
  },
  "scripts": {
    "start": "bun scripts/build-web-client.ts && electrobun dev",
    "dev": "bun scripts/build-web-client.ts && electrobun dev --watch",
    "build": "bun scripts/build-web-client.ts --minify && electrobun build",
    "build:dev": "bun scripts/build-web-client.ts --minify && electrobun build --env=dev",
    "build:canary": "bun scripts/build-web-client.ts --minify && electrobun build --env=canary",
    "build:stable": "bun scripts/build-web-client.ts --minify && electrobun build --env=stable",
    "build:cli": "bun scripts/build-cli.ts",
    "build:web-client": "bun scripts/build-web-client.ts",
    "package:mac": "bun scripts/build-web-client.ts --minify && electrobun build --env=stable",
    "test": "bun scripts/build-web-client.ts && bun test tests/",
    "test:e2e": "playwright test",
    "test:native": "playwright test --config=playwright-native.config.ts",
    "test:native:packaged": "HT_E2E_APP=packaged playwright test --config=playwright-native.config.ts",
    "test:native:design-review": "playwright test --config=playwright-native.config.ts --grep @design-review",
    "audit:test-hooks": "bun scripts/audit-test-hooks.ts",
    "test:all": "bun run test && bun run test:e2e",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^6.0.0",
    "electrobun": "1.16.0",
    "xterm": "5.3.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/parser": "^8.58.0",
    "happy-dom": "^20.9.0",
    "typescript-eslint": "^8.58.0",
    "ws": "^8.20.0"
  },
  "overrides": {
    "@types/node": "^20.19.0"
  }
}
